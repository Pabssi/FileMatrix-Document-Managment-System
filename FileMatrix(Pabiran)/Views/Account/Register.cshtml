@model FileMatrix_Pabiran_.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0" style="border-radius:16px;">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-1">Create Account</h4>
                <p class="text-muted mb-4">Get started with FileMatrix today</p>
                <partial name="_RegisterPartial" model="Model" />
                <div class="text-center mt-3 small text-muted">
                    Already have an account?
                    <a href="@Url.Action("Login", "Account")" class="fw-semibold text-decoration-none" style="color:#4f46e5;">Sign in</a>
                </div>
            </div>
        </div>
    </div>
</div>
