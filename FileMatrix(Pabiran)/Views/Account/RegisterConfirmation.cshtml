@{
    ViewData["Title"] = "Check your email";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 text-center" style="border-radius:16px;">
            <div class="card-body p-5">
                <div class="mb-4 d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px; background: #eef2ff; border-radius: 50%;">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                </div>
                <h3 class="fw-bold mb-2">Check your inbox</h3>
                <p class="text-muted mb-4">We've sent a verification link to your email address. Please click the link to confirm your account.</p>
                
                <div class="p-3 bg-light rounded-3 mb-4 small text-start">
                    <div class="d-flex gap-2 mb-2">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2" class="flex-shrink-0 mt-1"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                        <span>If you don't see the email, check your <strong>spam</strong> or junk folder.</span>
                    </div>
                    <div class="d-flex gap-2">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2" class="flex-shrink-0 mt-1"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                        <span>Verification links expire after 24 hours.</span>
                    </div>
                </div>

                <a href="/" class="btn btn-primary w-100 py-3 rounded-pill fw-bold" style="background: linear-gradient(135deg, #4f46e5, #6366f1); border: none;">
                    Back to Home
                </a>
            </div>
        </div>
    </div>
</div>
