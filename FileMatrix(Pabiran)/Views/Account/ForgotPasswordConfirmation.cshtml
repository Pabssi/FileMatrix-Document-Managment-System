@{
    ViewData["Title"] = "Check Your Email — FileMatrix";
}

<div class="fm-auth-page">
    <div class="fm-auth-card fm-confirm-card">

        <div class="fm-confirm-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <circle cx="24" cy="24" r="24" fill="#eef2ff"/>
                <path d="M12 18L24 27L36 18" stroke="#4f46e5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="10" y="16" width="28" height="20" rx="3" stroke="#4f46e5" stroke-width="2"/>
            </svg>
        </div>

        <h1 class="fm-auth-title">Check your email</h1>
        <p class="fm-auth-subtitle">
            If an account with that address exists, we've sent a password reset link.<br/>
            The link will expire in <strong>2 hours</strong>.
        </p>
        <p class="fm-auth-hint">
            Didn't receive it? Check your spam folder, or
            <a href="/Account/ForgotPassword" class="fm-inline-link">try again</a>.
        </p>

        <a href="/" class="fm-btn-primary fm-btn-center" style="text-decoration:none;display:block;text-align:center;margin-top:8px;">
            Back to sign in
        </a>

    </div>
</div>

@section Head {
    <style>
        body { background: linear-gradient(135deg, #f0f4ff 0%, #faf5ff 100%); min-height: 100vh; }
        .fm-auth-page { display:flex; align-items:center; justify-content:center; min-height:100vh; padding:24px; }
        .fm-auth-card { background:#fff; border-radius:20px; box-shadow:0 8px 40px rgba(79,70,229,.10); padding:40px 44px; width:100%; max-width:440px; text-align:center; }
        .fm-confirm-icon { margin-bottom:24px; }
        .fm-auth-title { font-size:1.55rem; font-weight:700; color:#1e1b4b; margin:0 0 12px; }
        .fm-auth-subtitle { color:#475569; font-size:.95rem; line-height:1.7; margin:0 0 16px; }
        .fm-auth-hint { font-size:.875rem; color:#94a3b8; margin:0 0 28px; }
        .fm-inline-link { color:#4f46e5; font-weight:500; }
        .fm-btn-primary { width:100%; padding:12px; background:linear-gradient(135deg,#4f46e5,#7c3aed); color:#fff; border:none; border-radius:10px; font-size:1rem; font-weight:600; cursor:pointer; transition:opacity .2s; }
        .fm-btn-primary:hover { opacity:.9; }
    </style>
}
