@{
    ViewData["Title"] = "Verify Identity — FileMatrix";
    var rememberMe = ViewData["RememberMe"] as bool? ?? false;
    var returnUrl = ViewData["ReturnUrl"] as string;
    var hasAuthenticator = ViewData["HasAuthenticator"] as bool? ?? false;
    var emailSentNotice = ViewData["EmailCodeSentNotice"] as bool? ?? false;
}

<div class="fm-auth-page">
    <div class="fm-auth-card">

        <div class="fm-auth-logo">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                <rect width="36" height="36" rx="10" fill="#4f46e5"/>
                <path d="M10 10h10l6 6v10H10V10z" fill="white" opacity=".9"/>
                <path d="M20 10l6 6h-6V10z" fill="white" opacity=".5"/>
            </svg>
            <span class="fm-auth-logo-text">FileMatrix</span>
        </div>

        <h1 class="fm-auth-title">Verify your identity</h1>
        @if (hasAuthenticator)
        {
            <p class="fm-auth-subtitle">Enter the 6-digit code from your authenticator app. If you cannot use the app, request a code by email below.</p>
        }
        else
        {
            <p class="fm-auth-subtitle">Two-step sign-in is on. We have sent a 6-digit code to your email — enter it below to continue.</p>
        }

        @if (emailSentNotice)
        {
            <p class="small text-success fw-semibold mb-3" role="status">A fresh code was sent to your email.</p>
        }

        <form method="post" asp-action="LoginWith2fa" asp-controller="Account" asp-route-returnUrl="@returnUrl">
            @Html.AntiForgeryToken()
            <input type="hidden" name="rememberMe" value="@rememberMe.ToString().ToLower()" />

            <div asp-validation-summary="All" class="fm-auth-error"></div>

            <div class="fm-field">
                <label for="code" class="fm-label">Verification code</label>
                <input id="code" name="code" type="text" class="fm-input fm-code-input"
                       placeholder="000000" maxlength="10" autocomplete="one-time-code" required autofocus />
            </div>

            <div class="mb-4 form-check">
                <input id="rememberMachine" name="rememberMachine" type="checkbox" class="form-check-input" value="true" />
                <label for="rememberMachine" class="form-check-label" style="font-size: .875rem; color: #475569;">Remember this device</label>
            </div>

            <button type="submit" class="fm-btn-primary">
                Verify & Sign In
            </button>
        </form>

        @if (hasAuthenticator)
        {
            <form method="post" asp-action="SendLoginTwoFactorEmail" asp-controller="Account" asp-route-returnUrl="@returnUrl" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="rememberMe" value="@rememberMe.ToString().ToLower()" />
                <input type="hidden" name="rememberMachine" value="false" />
                <button type="submit" class="btn btn-link fm-inline-link p-0 fw-semibold">Email me a sign-in code instead</button>
            </form>
        }
        else
        {
            <div class="fm-auth-footer">
                <p class="text-muted small mb-2">Didn't receive the code?</p>
                <form method="post" asp-action="SendLoginTwoFactorEmail" asp-controller="Account" asp-route-returnUrl="@returnUrl">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="rememberMe" value="@rememberMe.ToString().ToLower()" />
                    <input type="hidden" name="rememberMachine" value="false" />
                    <button type="submit" class="btn btn-link fm-inline-link p-0 fw-semibold">Send again</button>
                </form>
            </div>
        }

    </div>
</div>

@section Head {
    <style>
        body { background: linear-gradient(135deg, #f0f4ff 0%, #faf5ff 100%); min-height: 100vh; }
        .fm-auth-page { display:flex; align-items:center; justify-content:center; min-height:100vh; padding:24px; }
        .fm-auth-card { background:#fff; border-radius:20px; box-shadow:0 8px 40px rgba(79,70,229,.10); padding:40px 44px; width:100%; max-width:420px; text-align:center; }
        .fm-auth-logo { display:flex; align-items:center; justify-content:center; gap:10px; margin-bottom:28px; }
        .fm-auth-logo-text { font-size:1.25rem; font-weight:700; color:#1e1b4b; letter-spacing:-.3px; }
        .fm-auth-title { font-size:1.55rem; font-weight:700; color:#1e1b4b; margin:0 0 8px; }
        .fm-auth-subtitle { color:#64748b; font-size:.95rem; margin:0 0 32px; line-height:1.6; }
        .fm-auth-error { color:#dc2626; background:#fef2f2; border:1px solid #fecaca; border-radius:10px; padding:12px 16px; font-size:.9rem; margin-bottom:24px; text-align:left; display:none; }
        .fm-auth-error:not(:empty) { display:block; }
        .fm-field { margin-bottom:20px; }
        .fm-label { display:block; font-size:.875rem; font-weight:600; color:#374151; margin-bottom:10px; text-align:left; }
        .fm-input { width:100%; padding:14px; border:1.5px solid #e2e8f0; border-radius:12px; font-size:1.25rem; font-weight: 700; color:#1e1b4b; background:#f8fafc; transition:border-color .2s,box-shadow .2s; outline:none; text-align:center; letter-spacing: 8px; box-sizing: border-box; }
        .fm-input:focus { border-color:#4f46e5; background:#fff; box-shadow:0 0 0 4px rgba(79,70,229,.12); }
        .fm-btn-primary { width:100%; padding:14px; background:linear-gradient(135deg,#4f46e5,#7c3aed); color:#fff; border:none; border-radius:12px; font-size:1rem; font-weight:600; cursor:pointer; transition:opacity .2s,transform .1s; margin-top:4px; }
        .fm-btn-primary:hover { opacity:.92; transform:translateY(-1px); }
        .fm-auth-footer { margin-top:32px; }
        .fm-inline-link { color:#4f46e5; text-decoration:none; font-weight:600; }
        .fm-inline-link:hover { text-decoration:underline; }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const input = document.getElementById('code');
            if (!input) return;
            input.addEventListener('input', function() {
                this.value = this.value.replace(/[^0-9]/g, '');
            });
        });
    </script>
}
