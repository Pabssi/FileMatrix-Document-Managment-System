@{
    ViewData["Title"] = "Reset Password — FileMatrix";
    var token = ViewBag.Token as string ?? "";
    var email = ViewBag.Email as string ?? "";
}

<div class="fm-auth-page">
    <div class="fm-auth-card">

        <div class="fm-auth-logo">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                <rect width="36" height="36" rx="10" fill="#4f46e5"/>
                <path d="M10 10h10l6 6v10H10V10z" fill="white" opacity=".9"/>
                <path d="M20 10l6 6h-6V10z" fill="white" opacity=".5"/>
            </svg>
            <span class="fm-auth-logo-text">FileMatrix</span>
        </div>

        <h1 class="fm-auth-title">Choose a new password</h1>
        <p class="fm-auth-subtitle">Make it strong — at least 8 characters with a mix of letters and numbers.</p>

        <form method="post" asp-action="ResetPassword" asp-controller="Account" id="resetPasswordForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="token" value="@token" />
            <input type="hidden" name="email" value="@email" />

            <div asp-validation-summary="All" class="fm-auth-error"></div>

            <div class="fm-field">
                <label for="newPassword" class="fm-label">New password</label>
                <div class="fm-input-wrap">
                    <input id="newPassword" name="newPassword" type="password" class="fm-input"
                           placeholder="Min. 8 characters" autocomplete="new-password" required />
                    <button type="button" class="fm-eye-btn" data-target="newPassword" tabindex="-1" aria-label="Toggle visibility">
                        <svg class="fm-eye-icon" width="18" height="18" viewBox="0 0 24 24" fill="none">
                            <path d="M1 12C1 12 5 4 12 4C19 4 23 12 23 12C23 12 19 20 12 20C5 20 1 12 1 12Z" stroke="#94a3b8" stroke-width="1.8"/>
                            <circle cx="12" cy="12" r="3" stroke="#94a3b8" stroke-width="1.8"/>
                        </svg>
                    </button>
                </div>
                <div class="fm-strength-bar" id="strengthBar">
                    <div class="fm-strength-fill" id="strengthFill"></div>
                </div>
                <div class="fm-strength-label" id="strengthLabel"></div>
            </div>

            <div class="fm-field">
                <label for="confirmPassword" class="fm-label">Confirm new password</label>
                <div class="fm-input-wrap">
                    <input id="confirmPassword" name="confirmPassword" type="password" class="fm-input"
                           placeholder="Repeat your password" autocomplete="new-password" required />
                    <button type="button" class="fm-eye-btn" data-target="confirmPassword" tabindex="-1" aria-label="Toggle visibility">
                        <svg class="fm-eye-icon" width="18" height="18" viewBox="0 0 24 24" fill="none">
                            <path d="M1 12C1 12 5 4 12 4C19 4 23 12 23 12C23 12 19 20 12 20C5 20 1 12 1 12Z" stroke="#94a3b8" stroke-width="1.8"/>
                            <circle cx="12" cy="12" r="3" stroke="#94a3b8" stroke-width="1.8"/>
                        </svg>
                    </button>
                </div>
                <div class="fm-match-msg" id="matchMsg"></div>
            </div>

            <button type="submit" class="fm-btn-primary" id="resetSubmitBtn">
                Set new password
            </button>
        </form>

    </div>
</div>

@section Head {
    <style>
        body { background: linear-gradient(135deg, #f0f4ff 0%, #faf5ff 100%); min-height: 100vh; }
        .fm-auth-page { display:flex; align-items:center; justify-content:center; min-height:100vh; padding:24px; }
        .fm-auth-card { background:#fff; border-radius:20px; box-shadow:0 8px 40px rgba(79,70,229,.10); padding:40px 44px; width:100%; max-width:440px; }
        .fm-auth-logo { display:flex; align-items:center; gap:10px; margin-bottom:28px; }
        .fm-auth-logo-text { font-size:1.25rem; font-weight:700; color:#1e1b4b; letter-spacing:-.3px; }
        .fm-auth-title { font-size:1.55rem; font-weight:700; color:#1e1b4b; margin:0 0 8px; }
        .fm-auth-subtitle { color:#64748b; font-size:.95rem; margin:0 0 28px; line-height:1.6; }
        .fm-auth-error { color:#dc2626; background:#fef2f2; border:1px solid #fecaca; border-radius:10px; padding:12px 16px; font-size:.9rem; margin-bottom:20px; display:none; }
        .fm-auth-error:not(:empty) { display:block; }
        .fm-field { margin-bottom:20px; }
        .fm-label { display:block; font-size:.875rem; font-weight:600; color:#374151; margin-bottom:6px; }
        .fm-input-wrap { position:relative; }
        .fm-input { width:100%; padding:11px 40px 11px 14px; border:1.5px solid #e2e8f0; border-radius:10px; font-size:.95rem; color:#1e293b; background:#f8fafc; transition:border-color .2s,box-shadow .2s; outline:none; box-sizing:border-box; }
        .fm-input:focus { border-color:#4f46e5; background:#fff; box-shadow:0 0 0 3px rgba(79,70,229,.12); }
        .fm-eye-btn { position:absolute; right:12px; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; padding:2px; line-height:0; }
        .fm-strength-bar { height:4px; background:#e2e8f0; border-radius:4px; margin-top:8px; overflow:hidden; }
        .fm-strength-fill { height:100%; width:0; border-radius:4px; transition:width .3s, background .3s; }
        .fm-strength-label { font-size:.78rem; color:#64748b; margin-top:4px; min-height:16px; }
        .fm-match-msg { font-size:.8rem; margin-top:5px; min-height:16px; }
        .fm-btn-primary { width:100%; padding:12px; background:linear-gradient(135deg,#4f46e5,#7c3aed); color:#fff; border:none; border-radius:10px; font-size:1rem; font-weight:600; cursor:pointer; transition:opacity .2s,transform .1s; margin-top:4px; }
        .fm-btn-primary:hover { opacity:.92; transform:translateY(-1px); }
        .fm-btn-primary:disabled { opacity:.6; cursor:not-allowed; transform:none; }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Toggle password visibility
            document.querySelectorAll('.fm-eye-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var inp = document.getElementById(btn.dataset.target);
                    inp.type = inp.type === 'password' ? 'text' : 'password';
                });
            });

            // Password strength indicator
            var newPwd = document.getElementById('newPassword');
            var fill = document.getElementById('strengthFill');
            var label = document.getElementById('strengthLabel');
            var colors = ['#ef4444', '#f97316', '#eab308', '#22c55e'];
            var labels = ['Too weak', 'Weak', 'Fair', 'Strong'];

            newPwd.addEventListener('input', function () {
                var v = newPwd.value;
                var score = 0;
                if (v.length >= 8) score++;
                if (/[A-Z]/.test(v)) score++;
                if (/[0-9]/.test(v)) score++;
                if (/[^A-Za-z0-9]/.test(v)) score++;
                var pct = v.length === 0 ? 0 : Math.max(1, score) * 25;
                fill.style.width = pct + '%';
                fill.style.background = v.length === 0 ? '' : colors[Math.max(0, score - 1)];
                label.textContent = v.length === 0 ? '' : labels[Math.max(0, score - 1)];
                checkMatch();
            });

            // Match confirmation
            var confirm = document.getElementById('confirmPassword');
            var matchMsg = document.getElementById('matchMsg');
            function checkMatch() {
                if (!confirm.value) { matchMsg.textContent = ''; return; }
                if (newPwd.value === confirm.value) {
                    matchMsg.style.color = '#22c55e'; matchMsg.textContent = '✓ Passwords match';
                } else {
                    matchMsg.style.color = '#ef4444'; matchMsg.textContent = '✗ Passwords do not match';
                }
            }
            confirm.addEventListener('input', checkMatch);
        });
    </script>
}
