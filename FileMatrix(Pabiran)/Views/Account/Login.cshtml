@model FileMatrix_Pabiran_.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0" style="border-radius:16px;">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-1">Sign In</h4>
                <p class="text-muted mb-4">Enter your credentials to access your account</p>
                <partial name="_LoginPartial" model="Model" />
                <div class="text-center mt-3 small text-muted">
                    Don't have an account?
                    <a href="@Url.Action("Register", "Account")" class="fw-semibold text-decoration-none" style="color:#4f46e5;">Create Account</a>
                </div>
            </div>
        </div>
    </div>
</div>
