@{
    ViewData["Title"] = "Password Reset — FileMatrix";
}

<div class="fm-auth-page">
    <div class="fm-auth-card">

        <div class="fm-confirm-icon">
            <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
                <circle cx="28" cy="28" r="28" fill="#ecfdf5"/>
                <path d="M18 28L24 34L38 20" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>

        <h1 class="fm-auth-title">Password reset!</h1>
        <p class="fm-auth-subtitle">
            Your password has been updated successfully.<br/>
            You can now sign in with your new password.
        </p>

        <a href="/" class="fm-btn-primary" style="text-decoration:none;display:block;text-align:center;">
            Sign in now
        </a>

    </div>
</div>

@section Head {
    <style>
        body { background: linear-gradient(135deg, #f0f4ff 0%, #faf5ff 100%); min-height: 100vh; }
        .fm-auth-page { display:flex; align-items:center; justify-content:center; min-height:100vh; padding:24px; }
        .fm-auth-card { background:#fff; border-radius:20px; box-shadow:0 8px 40px rgba(79,70,229,.10); padding:40px 44px; width:100%; max-width:420px; text-align:center; }
        .fm-confirm-icon { margin-bottom:24px; }
        .fm-auth-title { font-size:1.65rem; font-weight:700; color:#1e1b4b; margin:0 0 12px; }
        .fm-auth-subtitle { color:#475569; font-size:.95rem; line-height:1.7; margin:0 0 32px; }
        .fm-btn-primary { padding:13px 24px; background:linear-gradient(135deg,#4f46e5,#7c3aed); color:#fff; border:none; border-radius:10px; font-size:1rem; font-weight:600; cursor:pointer; transition:opacity .2s; }
        .fm-btn-primary:hover { opacity:.9; }
    </style>
}
