@{
    ViewData["Title"] = "Join Organization";
    ViewData["HideMainNav"] = true;
}

<partial name="_OrgNav" />

@section Head {
    <link rel="stylesheet" href="~/css/pages/organizations.css" asp-append-version="true" />
}

<div class="orgs-page-wrapper orgs-join">
    <div class="orgs-bg-accent"></div>

    <div class="orgs-form-container">
        <div class="orgs-header">
            <div class="orgs-brand-badge">
                <div class="orgs-brand-dot"></div>
                <span class="orgs-brand-text">Collaboration</span>
            </div>
            <h1 class="orgs-title">Connect with Your Team</h1>
        </div>

        <div class="form-card">
            <div class="form-card-header">
                <a asp-action="Index" class="btn-back">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                </a>
                <div>
                    <h2 class="mb-0" style="font-size: 1.25rem; font-weight: 700; color: #0f172a;">Redeem Invitation</h2>
                    <p class="text-muted mb-0 small">Access shared resources immediately</p>
                </div>
            </div>

            <form asp-action="Join" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label class="form-label">Invitation Code</label>
                    <div class="premium-input-group">
                        <div class="input-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                            </svg>
                        </div>
                        <input type="text" name="token" class="premium-input" placeholder="XXXX-XXXX-XXXX" required />
                    </div>
                </div>

                <div class="help-box">
                    <div class="help-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </div>
                    <div>
                        <div class="fw-bold small" style="color: #0f172a;">Need an invite?</div>
                        <p class="mb-0 x-small text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                            Contact your organization administrator to request a secure invitation code for your workspace.
                        </p>
                    </div>
                </div>

                <button type="submit" class="btn-submit-premium">
                    Join Organization
                </button>
            </form>
        </div>

        <div class="text-center mt-4">
            <p class="small text-muted">
                Looking for your dashboard? <a asp-action="Index" class="text-decoration-none fw-semibold" style="color: #4f46e5;">Go back to selection</a>
            </p>
        </div>
    </div>
</div>


