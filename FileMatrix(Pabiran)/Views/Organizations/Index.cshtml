@{
    ViewData["Title"] = "Choose Your Workspace";
    ViewData["HideMainNav"] = true;
    var userName = User?.Identity?.Name ?? "Admin User";
}

<partial name="_OrgNav" />

@section Head {
    <link rel="stylesheet" href="~/css/pages/organizations.css" asp-append-version="true" />
}

<div class="orgs-page-wrapper orgs-index">
    <div class="orgs-bg-accent"></div>
    
    <div class="orgs-content mx-auto px-3">
        <div class="orgs-header">
            <div class="orgs-brand-badge">
                <div class="orgs-brand-dot"></div>
                <span class="orgs-brand-text">FileMatrix Workspace</span>
            </div>
            <h1 class="orgs-title">Welcome back, @userName</h1>
            <p class="orgs-subtitle">Choose how you'd like to proceed. You can create a new workspace or join an existing organization.</p>
        </div>

        <div class="row g-4">
            <!-- Your Workspaces Section -->
            @if (ViewBag.UserWorkspaces != null && ((dynamic)ViewBag.UserWorkspaces).Count > 0)
            {
                <div class="col-12 mb-4">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <h2 class="fw-bold text-dark mb-0">Your Workspaces</h2>
                        <div class="h-px flex-grow-1 bg-slate-200"></div>
                    </div>
                    <div class="row g-4">
                        @foreach (dynamic wp in ViewBag.UserWorkspaces)
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="org-selection-card @(!wp.IsActive ? "org-card-suspended" : "")">
                                    <div class="org-icon-box @(wp.IsActive ? "org-icon-box-primary" : "org-icon-box-muted")">
                                        @if (wp.IsActive)
                                        {
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                                                <polyline points="9 22 9 12 15 12 15 22"></polyline>
                                            </svg>
                                        }
                                        else
                                        {
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                            </svg>
                                        }
                                    </div>
                                    <h3 class="org-card-title h5 mb-1">@wp.Name</h3>
                                    <small class="text-muted fw-semibold text-uppercase ls-wide mb-3 d-block" style="font-size: 0.65rem;">@wp.RoleName</small>
                                    
                                    @if (wp.IsActive)
                                    {
                                        <form method="post" action="/Account/SwitchWorkplace">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@wp.WorkplaceID" />
                                            <button type="submit" class="org-card-btn org-card-btn-primary w-100">
                                                Enter Workspace
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                                    <polyline points="12 5 19 12 12 19"></polyline>
                                                </svg>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="org-card-btn org-card-btn-muted w-100" disabled>
                                            Suspended
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                            </svg>
                                        </button>
                                        <p class="text-danger small mt-2 mb-0 fw-medium">Access locked by administrator.</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="col-12">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <h2 class="fw-bold text-dark mb-0">Join or Create</h2>
                    <div class="h-px flex-grow-1 bg-slate-200"></div>
                </div>
            </div>

            <!-- Create Workspace -->
            <div class="col-md-6">
                <div class="org-selection-card">
                    <div class="org-icon-box org-icon-box-primary">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="12" y1="8" x2="12" y2="16"></line>
                            <line x1="8" y1="12" x2="16" y2="12"></line>
                        </svg>
                    </div>
                    <h3 class="org-card-title">Create Workspace</h3>
                    <p class="org-card-desc">Start a new instance for your business, team, or personal project. You'll be the administrator.</p>
                    <a asp-action="Create" class="org-card-btn org-card-btn-outline w-100">
                        Get Started
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Join Organization -->
            <div class="col-md-6">
                <div class="org-selection-card">
                    <div class="org-icon-box org-icon-box-secondary">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                    <h3 class="org-card-title">Join Organization</h3>
                    <p class="org-card-desc">Received an invitation? Enter your code to join your team and start collaborating immediately.</p>
                    <a asp-action="Join" class="org-card-btn org-card-btn-outline w-100">
                        Join with Code
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <div class="orgs-footer">
            Need help? Check our <a href="#">documentation</a> or contact <a href="#">support</a>.
        </div>
    </div>
</div>

@section Scripts {
}


