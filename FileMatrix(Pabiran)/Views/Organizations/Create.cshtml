@model FileMatrix_Pabiran_.Models.Workplace
@{
    ViewData["Title"] = "Create Workspace";
    ViewData["HideMainNav"] = true;
}

<partial name="_OrgNav" />

@section Head {
    <link rel="stylesheet" href="~/css/pages/organizations.css" asp-append-version="true" />
}

<div class="orgs-page-wrapper orgs-create">
    <div class="orgs-bg-accent"></div>

    <div class="orgs-form-container">
        <div class="orgs-header">
            <div class="orgs-brand-badge">
                <div class="orgs-brand-dot"></div>
                <span class="orgs-brand-text">Setup Wizard</span>
            </div>
            <h1 class="orgs-title">Create Your Workspace</h1>
        </div>

        <div class="form-card">
            <div class="form-card-header">
                <a asp-action="Index" class="btn-back">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                </a>
                <div>
                    <h2 class="mb-0" style="font-size: 1.25rem; font-weight: 700; color: #0f172a;">New Workspace</h2>
                    <p class="text-muted mb-0 small">Configure your instance in seconds</p>
                </div>
            </div>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="mb-4"></div>

                <div class="mb-4">
                    <label asp-for="Name" class="form-label">Workspace Name</label>
                    <input asp-for="Name" class="form-control premium-input" placeholder="e.g. Acme Studio" />
                    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-5">
                    <label class="form-label">Purpose</label>
                    <div class="workspace-type-grid">
                        <label class="type-tile">
                            <input asp-for="Description" type="radio" value="Business" checked />
                            <div class="type-content">
                                <span class="type-label">Business</span>
                                <span class="type-desc">For companies</span>
                            </div>
                        </label>
                        <label class="type-tile">
                            <input asp-for="Description" type="radio" value="Team" />
                            <div class="type-content">
                                <span class="type-label">Team</span>
                                <span class="type-desc">For groups</span>
                            </div>
                        </label>
                        <label class="type-tile">
                            <input asp-for="Description" type="radio" value="Personal" />
                            <div class="type-content">
                                <span class="type-label">Personal</span>
                                <span class="type-desc">Individual</span>
                            </div>
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn-submit-premium">
                    Launch Workspace
                </button>
            </form>
        </div>

        <div class="text-center mt-4">
            <p class="small text-muted">
                By creating a workspace, you agree to our 
                <a href="#" class="text-decoration-none fw-semibold" style="color: #64748b;">Terms of Service</a>
            </p>
        </div>
    </div>
</div>


