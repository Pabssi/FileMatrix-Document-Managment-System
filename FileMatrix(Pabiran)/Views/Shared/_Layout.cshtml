@*
    FileMatrix Master Layout.
    
    RESPONSIBILITY: Defines the global framing, navigation, and notification infrastructure.
    DESIGN: Supports a 'Clean Canvas' mode (hideMainNav) for document viewing and 
    implements a centralized modal system (AuthModal) and Toast alert pipeline.
*@
@{
    bool hideMainNav = ViewData["hideMainNav"] != null && (bool)ViewData["hideMainNav"]!;
}
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FileMatrix_Pabiran_</title>
    <link rel="icon" type="image/png" href="~/images/FileMatrix.png" />
    <!-- Google reCAPTCHA v3 -->
    <script src="https://www.google.com/recaptcha/api.js?render=@Configuration["Recaptcha:SiteKey"]"></script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FileMatrix_Pabiran_.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/shared/auth.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <header>
        @* REFINEMENT: The 'Hide Main Nav' pattern. 
           Allows specialized views (like the Shared Document view) to strip away 
           the global navigation for a full-screen, focused experience. *@
        @if (!hideMainNav)
        {
            <div class="app-navbar-container">
                <nav class="navbar navbar-expand-lg app-navbar">
                    <div class="container-fluid">
                        <a class="app-nav-logo" asp-area="" asp-controller="Home" asp-action="Index">
                            <img src="~/images/FileMatrix.png" alt="Logo" height="32" />
                            <span class="landing-nav-logo-text fw-bold">FileMatrix</span>
                        </a>

                        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                             <span class="navbar-toggler-icon"></span>
                        </button>

                        <div class="collapse navbar-collapse" id="mainNav">
                            <ul class="navbar-nav me-auto">
                                <li class="nav-item"><a class="app-nav-link" asp-area="Admin" asp-controller="Admin" asp-action="Index">Workplace</a></li>
                                <li class="nav-item"><a class="app-nav-link" href="#features">Features</a></li>
                                <li class="nav-item"><a class="app-nav-link" href="#benefits">Benefits</a></li>
                            </ul>

                            <div class="d-flex align-items-center">
                                <partial name="~/Views/Shared/_LoginPartial.cshtml" />
                            </div>
                        </div>
                    </div>
                </nav>
            </div>
        }
    </header>
    <partial name="_AuthModal" />
    @if (hideMainNav)
    {
        <main role="main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    <!-- Global Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="globalToast" class="toast premium-toast hide align-items-center" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center gap-2">
                    <span id="globalToastIcon"></span>
                    <span id="globalToastMessage" class="fw-medium text-dark"></span>
                </div>
                <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <link rel="stylesheet" href="~/css/shared/layout-toast.css" asp-append-version="true" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/auth-modal.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // UNIFIED NOTIFICATION SYSTEM: 
        // Automatically maps TempData messages and ReturnUrl redirects to the 
        // global toast or authentication modal upon page load.
        $(document).ready(function() {
            // Auto-trigger login modal if ReturnUrl is present (means unauthorized redirect)
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('ReturnUrl')) {
                const modalEl = document.getElementById('authModal');
                if (modalEl && window.bootstrap && bootstrap.Modal) {
                    const authModal = new bootstrap.Modal(modalEl);
                    authModal.show();
                }
            }

            // Handle TempData messages on load
            @if (TempData["SuccessMessage"] != null) {
                <text>showToast('@Html.Raw(TempData["SuccessMessage"])', 'success');</text>
            }
            @if (TempData["ErrorMessage"] != null) {
                <text>showToast('@Html.Raw(TempData["ErrorMessage"])', 'error');</text>
            }

            // Specialized Invite Login Prompt
            @if (TempData["InviteLoginPrompt"] != null) {
                <text>
                (function() {
                    const modalEl = document.getElementById('authModal');
                    const alertContainer = document.getElementById('authModalAlertContainer');
                    if (modalEl && alertContainer && window.bootstrap && bootstrap.Modal) {
                        alertContainer.innerHTML = `
                                <div class="alert alert-primary auth-invite-alert reveal-fade-in">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                                    <span class="fw-bold small">@Html.Raw(TempData["InviteLoginPrompt"])</span>
                                </div>
                        `;
                        const authModal = new bootstrap.Modal(modalEl);
                        authModal.show();
                    }
                })();
                </text>
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
