@model FileMatrix_Pabiran_.Models.DocumentDetailsViewModel
@*
    FileMatrix Document Workspace (Details).
    
    RESPONSIBILITY: Provides a high-fidelity environment for reviewing, 
    previewing, and discussing specific assets.
    
    ARCHITECTURE:
    1. Preview Engine: Multi-stack renderer (Image Zoom, PDF Iframe, Office Online).
    2. Side-Channel: Threaded discussion and contextual metadata.
    3. Permission Isolation: Checks for shared tokens to support external previewing.
*@

@{
    ViewData["Title"] = Model.Document.Title + " - Admin Details";
    Layout = "_Layout"; 
}

@section Head {
    <link rel="stylesheet" href="~/css/admin/document-details.css" asp-append-version="true" />
    <style>
        /* Sharing Modal Extensions */
        .hover-bg-light:hover { background-color: #f8fafc; }
        .transition-all { transition: all 0.2s ease-in-out; }
        .custom-dropdown-toggle::after { display: none; }
        .people-avatar {
            width: 36px; height: 36px; 
            background: #4f46e5; color: white;
            display: flex; align-items: center; justify-content: center;
            border-radius: 50%; font-weight: bold; font-size: 0.85rem;
        }
    </style>
}

<div class="details-container">
    <div class="preview-pane">
        <div class="preview-header">
            <div class="d-flex align-items-center gap-3">
                <a href="@Url.Action("Index")" class="btn-action btn-back">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
                    Back
                </a>
                
                <div class="d-flex align-items-center gap-2">
                    <div class="p-2 rounded-3" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                        @if (Model.Document.IsWord)
                        {
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2b579a" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><path d="M9 13h6"></path><path d="M9 17h3"></path></svg>
                        }
                        else if (Model.Document.IsExcel)
                        {
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#217346" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><path d="M8 13h8v4H8z"></path><path d="M12 13v4"></path></svg>
                        }
                        else if (Model.Document.IsPowerPoint)
                        {
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d24726" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><circle cx="12" cy="13" r="2"></circle><path d="M12 15v2"></path></svg>
                        }
                        else if (Model.Document.IsPdf)
                        {
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e11d48" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><path d="M9 17h6"></path><path d="M12 12V17"></path></svg>
                        }
                        else if (Model.Document.IsImage)
                        {
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9333ea" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                        }
                        else if (Model.Document.IsVideo)
                        {
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0891b2" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><polygon points="10 8 10 12 13 10 10 8"></polygon><line x1="2" y1="17" x2="22" y2="17"></line><line x1="2" y1="21" x2="22" y2="21"></line></svg>
                        }
                        else
                        {
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                        }
                    </div>
                    <div>
                        <h5 class="fw-bold text-dark m-0">@Model.Document.Title</h5>
                        <div class="d-flex align-items-center gap-1">
                            <span class="badge bg-primary-subtle text-primary border-0 rounded-pill px-2 py-1" style="font-size: 0.65rem;">@Model.Document.CategoryName.ToUpper()</span>
                            @if (User.Identity?.IsAuthenticated == true && ViewBag.CurrentMembership?.RoleID <= 1)
                            {
                                <span class="badge bg-dark-subtle text-dark border-0 rounded-pill px-2 py-1" style="font-size: 0.65rem;">ADMIN</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2">
                @{
                    var wpMembership = ViewBag.CurrentMembership as FileMatrix_Pabiran_.Models.WorkplaceMember;
                    var canEditDoc = wpMembership?.RoleID <= 2;
                }
                @if (canEditDoc || Model.Document.IsShared)
                {
                    <button class="btn-action btn-share" id="share-btn" data-id="@Model.Document.DocumentID">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                        Share
                    </button>
                }
                @{
                    var downloadUrl = Url.Action("Download", new { id = Model.Document.DocumentID, token = Context.Request.Query["token"] });
                }
                <a href="@downloadUrl" class="btn-action btn-download">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"></svg>
                    Download
                </a>
            </div>
        </div>
        @* THE PREVIEW ENGINE: 
           Branching logic that determines the best renderer for each MIME type.
           Supports a 'Physical-Direct' stream for images/PDFs and a 
           'Cloud-Proxy' (Microsoft Office Online) for proprietary formats. *@
        <div class="preview-body">
            @if (Model.Document.IsImage)
            {
                var token = Context.Request.Query["token"];
                var viewFileUrl = Url.Action("ViewFile", new { id = Model.Document.DocumentID, token = token });
                <div class="image-viewport" id="image-viewport">
                    <img src="@viewFileUrl" class="zoomable-image" id="target-image" />
                </div>
                <div class="zoom-toolbar">
                    <button class="zoom-btn" id="zoom-out" title="Zoom Out">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    </button>
                    <span class="zoom-level" id="zoom-text">100%</span>
                    <button class="zoom-btn" id="zoom-in" title="Zoom In">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    </button>
                    <div style="width: 1px; height: 20px; background: #e2e8f0; margin: 0 0.25rem;"></div>
                    <button class="zoom-btn" id="zoom-reset" title="Reset Zoom">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><polyline points="3 3 3 8 8 8"></polyline></svg>
                    </button>
                </div>
            }
            else if (Model.Document.IsOfficeDocument)
            {
                var qToken = Context.Request.Query["token"].ToString();
                var activeToken = !string.IsNullOrEmpty(qToken) ? qToken : Model.Document.PublicShareToken;
                
                if (string.IsNullOrEmpty(activeToken))
                {
                    <div class="h-100 d-flex align-items-center justify-content-center bg-white">
                        <div class="text-center p-5 max-w-400">
                            <div class="mb-4 text-indigo shadow-sm d-inline-block p-3 rounded-circle bg-indigo-subtle">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                            </div>
                            <h4 class="fw-bold text-dark">Office Preview</h4>
                            <p class="text-muted">Direct preview for Word, Excel, and PowerPoint files requires <strong>Public Sharing</strong> to be enabled so Microsoft's viewer can fetch the file.</p>
                            @if (canEditDoc || Model.Document.IsShared)
                            {
                                <button class="btn btn-primary rounded-pill px-4 fw-bold share-doc" data-id="@Model.Document.DocumentID">
                                    @(Model.Document.IsShared ? "View Public Link" : "Enable sharing to preview")
                                </button>
                            }
                            else
                            {
                                <div class="alert alert-info border-0 rounded-4 small">
                                    Preview is unavailable. Please ask an Editor or Administrator to enable sharing.
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    // Microsoft Office Online Viewer requires a publicly accessible URL.
                    // We use the pre-signed direct Cloudinary URL if available, fallback to the ViewFile proxy.
                    var publicUrl = Model.Document.SignedUrl ?? Url.Action("ViewFile", "Documents", new { area = "Admin", id = Model.Document.DocumentID, token = activeToken }, Context.Request.Scheme);
                    var officeViewerUrl = $"https://view.officeapps.live.com/op/embed.aspx?src={System.Net.WebUtility.UrlEncode(publicUrl)}&wdPrint=0&wdEmbed=1";
                    
                    <div class="h-100 d-flex flex-column position-relative" style="overflow: hidden; background: #f3f2f1;">
                        @if (Context.Request.Host.Host.Contains("localhost"))
                        {
                            <div class="alert alert-warning m-2 small border-0 shadow-sm rounded-3" style="position: absolute; bottom: 0; left: 0; right: 0; z-index: 10; opacity: 0.9;">
                                <div class="d-flex align-items-center gap-2">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                                    <strong>Dev Mode:</strong> Microsoft Viewer cannot see files on localhost.
                                </div>
                            </div>
                        }
                        <iframe src="@officeViewerUrl" class="preview-iframe" style="position: absolute; top: -38px; left: 0; width: 100%; height: calc(100% + 38px); border: none;"></iframe>
                    </div>
                }
            }
            else
            {
                <iframe src="@Url.Action("ViewFile", new { id = Model.Document.DocumentID, token = Context.Request.Query["token"] })" class="preview-iframe"></iframe>
            }
        </div>
    </div>

    <div class="details-sidebar">
        @if (User.Identity?.IsAuthenticated == true && ViewBag.CurrentWorkplace?.WorkplaceID == Model.WorkplaceID)
        {
            <div class="sidebar-section">
                <div class="sidebar-title">Information</div>
                <div class="meta-list">
                    <div class="meta-item">
                        <span class="meta-label">Status</span>
                        <span class="badge-status badge-@(Model.Document.Status.ToLower())">@Model.Document.Status</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Category</span>
                        <span class="meta-value">@Model.Document.CategoryName</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Version</span>
                        <span class="meta-value">
                            @("v" + Model.Document.CurrentVersionNumber)
                            <a href="#" class="ms-2 text-primary text-decoration-none small view-history" data-id="@Model.Document.DocumentID" data-title="@Model.Document.Title">
                                (History)
                            </a>
                        </span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">File Size</span>
                        <span class="meta-value">@Model.Document.FileSizeFormatted</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Uploaded By</span>
                        <span class="meta-value">@Model.Document.UploadedBy</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Updated At</span>
                        <span class="meta-value">@Model.Document.UpdatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Document.GoogleDriveLink))
                    {
                        <div class="meta-item mt-2">
                            <span class="meta-label text-success">Cloud Backup</span>
                            <span class="meta-value">
                                <a href="@Model.Document.GoogleDriveLink" target="_blank" class="text-indigo fw-bold text-decoration-none d-flex align-items-center gap-1">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                                    View in Drive
                                </a>
                            </span>
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(Model.Document.Description))
                {
                    <div class="mt-4">
                        <div class="sidebar-title" style="font-size: 0.75rem;">Description</div>
                        <p class="text-muted small mb-0">@Model.Document.Description</p>
                    </div>
                }
            </div>
        }

        @* SIDE-CHANNEL: DISCUSSION & META. 
           Separates asset content from administrative context and social interaction.
           Ensures that discussion history never obscures the document itself. *@
        <div class="sidebar-section" style="flex-grow: 1;">
            <div class="sidebar-title">Discussion</div>
            <div class="comments-list" id="comments-container">
                @if (!Model.Comments.Any())
                {
                    <div class="text-center py-4 text-muted small" id="no-comments-msg">
                        No comments yet. Start the conversation.
                    </div>
                }
                @foreach (var comment in Model.Comments)
                {
                    <div class="comment-card shadow-sm border-0 mb-2">
                        <div class="comment-user">@comment.UserDisplayName</div>
                        <div class="comment-text">@comment.Text</div>
                        <div class="comment-date text-end">@comment.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                    </div>
                }
            </div>
        </div>

        <div class="comment-input-wrap">
            <form id="comment-form">
                <input type="hidden" name="documentId" value="@Model.Document.DocumentID" />
                <textarea name="text" class="comment-textarea" placeholder="Add an admin note or comment..." rows="3"></textarea>
                <button type="submit" class="btn btn-primary w-100 mt-2 fw-bold" style="border-radius: 0.75rem;">Post Comment</button>
            </form>
        </div>
    </div>
</div>

<!-- Share Modal (Google Docs Style) -->
<div class="modal fade" id="shareModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content rounded-4 shadow border-0" style="overflow:hidden;">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bold text-dark" style="font-size: 1.25rem;">Share "@Model.Document.Title"</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3 pb-4 px-4">
                <!-- Add People Section -->
                <div class="mb-4">
                    <div class="input-group shadow-sm rounded-3 overflow-hidden border">
                        <input type="text" class="form-control border-0 bg-light py-3 px-3" id="share-email-input" placeholder="Add people and groups">
                        <select class="form-select border-0 bg-light text-muted fw-bold" style="max-width: 110px;" id="share-role-input">
                            <option value="Viewer" selected>Viewer</option>
                            <option value="Editor">Editor</option>
                        </select>
                        <button class="btn btn-primary fw-bold px-4" id="share-invite-btn">Send</button>
                    </div>
                </div>

                <!-- People List -->
                <h6 class="fw-bold text-muted small mb-3">People with access</h6>
                <div class="d-flex flex-column gap-3 mb-4" id="share-people-list" style="max-height: 200px; overflow-y: auto;">
                    <!-- Loading State -->
                    <div class="text-center py-3 text-muted">
                        <div class="spinner-border spinner-border-sm me-2"></div> Loading...
                    </div>
                </div>

                <!-- General Access -->
                <h6 class="fw-bold text-muted small mb-3">General access</h6>
                <div class="d-flex align-items-center justify-content-between p-2 rounded-3 hover-bg-light transition-all">
                    <div class="d-flex align-items-center gap-3">
                        <div class="d-flex align-items-center justify-content-center rounded-circle bg-light text-muted transition-all" id="general-access-bg" style="width: 40px; height: 40px; min-width: 40px;">
                            <svg id="general-access-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                        </div>
                        <div class="d-flex flex-column">
                            <div class="dropdown">
                                <button class="btn btn-link p-0 fw-bold shadow-none text-dark d-flex align-items-center gap-2 dropdown-toggle custom-dropdown-toggle" type="button" id="general-access-dropdown" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.95rem; text-decoration: none;">
                                    <span id="general-access-label">Restricted</span>
                                </button>
                                <ul class="dropdown-menu border-0 shadow-lg p-2 rounded-3" aria-labelledby="general-access-dropdown" style="min-width: 200px;">
                                    <li><a class="dropdown-item rounded-2 py-2 access-opt" href="#" data-val="Restricted">Restricted</a></li>
                                    <li><a class="dropdown-item rounded-2 py-2 access-opt" href="#" data-val="Public">Anyone with the link</a></li>
                                </ul>
                            </div>
                            <div class="text-muted small" id="general-access-desc" style="font-size: 0.75rem; opacity: 0.8;">Only people with access can open with the link</div>
                        </div>
                    </div>
                    <div id="public-role-wrapper" style="display:none;">
                       <div class="dropdown">
                            <button class="btn btn-link p-0 fw-bold shadow-none text-primary d-flex align-items-center gap-2 dropdown-toggle custom-dropdown-toggle" type="button" id="public-role-dropdown" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.95rem; text-decoration: none;">
                                <span id="public-role-label">Viewer</span>
                            </button>
                            <ul class="dropdown-menu border-0 shadow-lg p-2 rounded-3 dropdown-menu-end" aria-labelledby="public-role-dropdown">
                                <li><a class="dropdown-item rounded-2 py-2 role-opt" href="#" data-val="Viewer">Viewer</a></li>
                                <li><a class="dropdown-item rounded-2 py-2 role-opt" href="#" data-val="Editor">Editor</a></li>
                            </ul>
                       </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top pt-3 px-4 pb-4 justify-content-between">
                <button type="button" class="btn btn-outline-primary rounded-pill fw-bold px-4 d-flex align-items-center gap-2" id="share-copy-link-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                    <span id="copy-link-text">Copy link</span>
                </button>
                <button type="button" class="btn btn-primary rounded-pill fw-bold px-4" data-bs-dismiss="modal">Done</button>
            </div>
        </div>
    </div>
</div>

<!-- Version History Modal -->
<partial name="_VersionHistoryModal" />

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#comment-form').submit(function (e) {
                e.preventDefault();

                @if (User.Identity?.IsAuthenticated != true)
                {
                    <text>
                    const modalEl = document.getElementById('authModal');
                    if (modalEl && window.bootstrap && bootstrap.Modal) {
                        const authModal = new bootstrap.Modal(modalEl);
                        authModal.show();
                    }
                    return;
                    </text>
                }

                var form = $(this);
                var text = form.find('textarea[name="text"]').val();
                if (!text.trim()) return;

                $.post('@Url.Action("AddComment")', form.serialize(), function (res) {
                    if (res.success) {
                        $('#no-comments-msg').hide();
                        var html = `
                            <div class="comment-card shadow-sm border-0 mb-2" style="display: none; background: #f0f4ff;">
                                <div class="comment-user">${res.comment.userDisplayName}</div>
                                <div class="comment-text">${res.comment.text}</div>
                                <div class="comment-date text-end">${res.comment.createdAt}</div>
                            </div>
                        `;
                        var el = $(html);
                        $('#comments-container').prepend(el);
                        el.fadeIn();
                        form.find('textarea[name="text"]').val('');
                    } else {
                        alert(res.message);
                    }
                });
            });

            @if (Model.Document.IsImage)
            {
                <text>
                var scale = 1.0;
                var $img = $('#target-image');
                var $viewport = $('#image-viewport');

                function updateZoom() {
                    $img.css('transform', `scale(${scale})`);
                    $('#zoom-text').text(Math.round(scale * 100) + '%');
                }

                $('#zoom-in').click(function() {
                    scale = Math.min(scale + 0.2, 5);
                    updateZoom();
                });

                $('#zoom-out').click(function() {
                    scale = Math.max(scale - 0.2, 0.2);
                    updateZoom();
                });

                $('#zoom-reset').click(function() {
                    scale = 1.0;
                    updateZoom();
                });

                // Pan functionality
                var isPanning = false;
                var startX, startY, scrollLeft, scrollTop;

                $viewport.on('mousedown', function(e) {
                    if (e.target.id === 'image-viewport' || e.target.id === 'target-image') {
                        isPanning = true;
                        startX = e.pageX - $viewport.offset().left;
                        startY = e.pageY - $viewport.offset().top;
                        scrollLeft = $viewport.scrollLeft();
                        scrollTop = $viewport.scrollTop();
                    }
                });

                $(window).on('mouseup', function() {
                    isPanning = false;
                });

                $viewport.on('mousemove', function(e) {
                    if (!isPanning) return;
                    e.preventDefault();
                    var x = e.pageX - $viewport.offset().left;
                    var y = e.pageY - $viewport.offset().top;
                    var walkX = (x - startX);
                    var walkY = (y - startY);
                    $viewport.scrollLeft(scrollLeft - walkX);
                    $viewport.scrollTop(scrollTop - walkY);
                });
                </text>
            }

            // Share Document Logic (Unified)
            var currentShareDocId = @Model.Document.DocumentID;

            $('#share-btn').click(function(e) {
                e.preventDefault();
                $('#shareModal').modal('show');
                loadShareDetails(currentShareDocId);
            });

            function loadShareDetails(docId) {
                $('#share-people-list').html('<div class="text-center py-3 text-muted"><div class="spinner-border spinner-border-sm me-2"></div> Loading...</div>');
                $.get('@Url.Action("GetShareStatus")', { id: docId }, function(res) {
                    if (res.success) {
                        renderShareUI(res);
                    } else {
                        $('#share-people-list').html('<div class="text-center text-danger py-2">Failed to load details</div>');
                    }
                });
            }

            function renderShareUI(data) {
                var peopleListHtml = '';
                if (data.owner) peopleListHtml += renderPersonItem(data.owner, 'Owner', false);
                if (data.permissions) data.permissions.forEach(p => peopleListHtml += renderPersonItem(p, p.role, true, false));
                if (data.pendingInvites) data.pendingInvites.forEach(i => peopleListHtml += renderPersonItem(i, i.role, false, true));
                $('#share-people-list').html(peopleListHtml);

                if (data.isPublic) {
                    $('#general-access-label').text('Anyone with the link');
                    $('#public-role-label').text(data.publicAccessLevel);
                    $('#public-role-wrapper').show();
                    $('#general-access-desc').text('Anyone with the link can ' + data.publicAccessLevel.toLowerCase());
                    $('#general-access-icon').html('<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>');
                    $('#general-access-bg').removeClass('bg-light').addClass('bg-primary-subtle text-primary');
                } else {
                    $('#general-access-label').text('Restricted');
                    $('#public-role-wrapper').hide();
                    $('#general-access-desc').text('Only people with access can open with the link');
                    $('#general-access-icon').html('<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>');
                    $('#general-access-bg').addClass('bg-light').removeClass('bg-primary-subtle text-primary');
                }
                $('#share-copy-link-btn').data('link', data.publicLink);
            }

            function renderPersonItem(user, role, isRemovable, isPending) {
                var name = user.userDisplayName || user.email || '?';
                var initial = name.charAt(0).toUpperCase();
                var email = user.email || '';
                var removeBtn = isRemovable ? `<button class="btn btn-sm btn-link text-muted p-0 remove-perm-btn" data-id="${user.userID}" title="Remove access">×</button>` : '';
                return `<div class="d-flex align-items-center justify-content-between py-1">
                            <div class="d-flex align-items-center gap-3">
                                <div class="people-avatar">${initial}</div>
                                <div><div class="fw-bold small">${name}${isPending?' (Pending)':''}</div><div class="text-muted" style="font-size:0.7rem;">${email}</div></div>
                            </div>
                            <div class="d-flex align-items-center gap-3"><span class="text-muted small fw-bold">${role}</span>${removeBtn}</div>
                        </div>`;
            }

            $(document).on('click', '.access-opt', function(e) {
                e.preventDefault();
                var val = $(this).data('val');
                updatePublicAccess(val === 'Public', 'Viewer');
            });

            $(document).on('click', '.role-opt', function(e) {
                e.preventDefault();
                updatePublicAccess(true, $(this).data('val'));
            });

            function updatePublicAccess(enabled, level) {
                $.post('@Url.Action("UpdatePublicAccess")', { id: currentShareDocId, enabled: enabled, level: level }, function(res) {
                    if (res.success) loadShareDetails(currentShareDocId);
                    else alert('Failed to update access.');
                });
            }

            $('#share-invite-btn').click(function() {
                var email = $('#share-email-input').val();
                var role = $('#share-role-input').val();
                if (!email) return;
                var btn = $(this); btn.prop('disabled', true).text('...');
                $.post('@Url.Action("AddUserPermission")', { id: currentShareDocId, email: email, role: role }, function(res) {
                    btn.prop('disabled', false).text('Send');
                    if (res.success) { $('#share-email-input').val(''); loadShareDetails(currentShareDocId); }
                    else alert(res.message);
                });
            });

            $(document).on('click', '.remove-perm-btn', function() {
                var userId = $(this).data('id');
                if (confirm('Remove access?')) {
                    $.post('@Url.Action("RemoveUserPermission")', { id: currentShareDocId, userId: userId }, function(res) {
                        if (res.success) loadShareDetails(currentShareDocId);
                    });
                }
            });

            $('#share-copy-link-btn').click(function() {
                var link = $(this).data('link');
                var textSpan = $('#copy-link-text');
                navigator.clipboard.writeText(link).then(function() {
                    textSpan.text('Link copied!');
                    setTimeout(() => textSpan.text('Copy link'), 2000);
                });
            });

            // Version History timeline
            $('.view-history').click(function(e) {
                e.preventDefault();
                var id = $(this).data('id');
                var title = $(this).data('title');
                $('#historyModalTitle').text('Version History');
                $('#historyModalSubtitle').text(title);
                loadVersionHistory(id);
                $('#versionHistoryModal').modal('show');
            });

            function loadVersionHistory(id) {
                $('#version-history-timeline').html('<div class="text-center py-4 text-muted"><div class="spinner-border spinner-border-sm me-2"></div> Loading...</div>');
                $.get('@Url.Action("VersionHistory")', { id: id }, function(res) {
                    if (res.success) {
                        var html = '';
                        res.versions.forEach(function(v) {
                            html += `
                                <div class="version-card">
                                    <div class="version-dot"></div>
                                    <div class="version-header">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="p-2 bg-primary-subtle rounded-3">
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                            </div>
                                            <span class="version-title">Version ${v.versionNumber}</span>
                                            ${v.isCurrent ? '<span class="version-badge bg-success-subtle text-success">Current</span>' : ''}
                                        </div>
                                    </div>
                                    <div class="version-meta">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                        ${v.uploadedAt}
                                    </div>
                                    <div class="version-meta">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                        ${v.uploadedBy}
                                    </div>
                                    <div class="small fw-bold text-muted mt-2">Size: ${v.fileSize}</div>
                                    ${v.changeNote ? `<div class="version-notes"><strong>Changes:</strong> ${v.changeNote}</div>` : ''}
                                    <div class="mt-3 d-flex gap-2">
                                        <a href="/Admin/Documents/Download/${id}?versionId=${v.versionID}" class="btn btn-sm btn-primary fw-bold" style="border-radius:6px; font-size:0.75rem;">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="me-1"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
                                            Download
                                        </a>
                                        ${!v.isCurrent && v.canRestore ? `
                                            <div class="restore-wrapper" data-vid="${v.versionID}">
                                                <button class="btn btn-sm btn-outline-secondary fw-bold restore-btn" style="border-radius:6px; font-size:0.75rem;">Restore</button>
                                                <div class="restore-confirm d-none gap-2">
                                                    <span class="small fw-bold text-danger me-1">Confirm?</span>
                                                    <button class="btn btn-sm btn-danger fw-bold confirm-restore-btn" style="border-radius:6px; font-size:0.75rem; padding: 0.25rem 0.6rem;">Yes</button>
                                                    <button class="btn btn-sm btn-light border fw-bold cancel-restore-btn" style="border-radius:6px; font-size:0.75rem; padding: 0.25rem 0.6rem;">No</button>
                                                </div>
                                            </div>
                                        ` : ''}
                                    </div>
                                </div>
                            `;
                        });
                        $('#version-history-timeline').html(html || '<div class="text-center py-4 text-muted">No history found.</div>');
                        
                        // Attach restore handlers
                        $('.restore-btn').click(function() {
                            var wrapper = $(this).closest('.restore-wrapper');
                            $(this).hide();
                            wrapper.find('.restore-confirm').removeClass('d-none').addClass('d-flex align-items-center');
                        });

                        $('.cancel-restore-btn').click(function() {
                            var wrapper = $(this).closest('.restore-wrapper');
                            wrapper.find('.restore-confirm').addClass('d-none').removeClass('d-flex');
                            wrapper.find('.restore-btn').show();
                        });

                        $('.confirm-restore-btn').click(function() {
                            var wrapper = $(this).closest('.restore-wrapper');
                            var vid = wrapper.data('vid');
                            var btn = $(this);
                            
                            btn.prop('disabled', true).text('...');
                            wrapper.find('.cancel-restore-btn').hide();
                            
                            $.post('@Url.Action("RestoreVersion")', { versionId: vid }, function(r) {
                                if (r.success) {
                                    location.reload();
                                } else {
                                    alert('Failed to restore: ' + r.message);
                                    btn.prop('disabled', false).text('Yes');
                                    wrapper.find('.cancel-restore-btn').show();
                                }
                            }).fail(function() {
                                alert('Server error occurred while restoring.');
                                btn.prop('disabled', false).text('Yes');
                                wrapper.find('.cancel-restore-btn').show();
                            });
                        });
                    }
                });
            }

            // Version Upload handlers
            // Manual click handler removed as label handles it natively now

            $('#version-file-input').change(function() {
                if (this.files && this.files.length > 0) {
                    $('#upload-form-area').slideDown();
                    $('#version-upload-trigger').hide();
                }
            });

            $('#cancel-version-upload').click(function() {
                $('#upload-form-area').slideUp();
                $('#version-upload-trigger').show();
                $('#version-file-input').val('');
                $('#version-notes-input').val('');
            });

            $('#submit-version-upload').click(function() {
                var fileInput = document.getElementById('version-file-input');
                if (!fileInput.files || fileInput.files.length == 0) return;

                // Check file size (100MB limit)
                if (fileInput.files[0].size > 104857600) {
                    alert('File is too large. Maximum size is 100MB.');
                    return;
                }

                var formData = new FormData();
                formData.append('documentId', '@Model.Document.DocumentID');
                formData.append('file', fileInput.files[0]);
                formData.append('changeNote', $('#version-notes-input').val());

                var btn = $(this);
                btn.prop('disabled', true).text('Uploading...');

                $.ajax({
                    url: '@Url.Action("UploadVersion")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(r) {
                        if (r.success) {
                            location.reload();
                        } else {
                            alert('Upload failed: ' + r.message);
                            btn.prop('disabled', false).text('Submit Changes');
                        }
                    },
                    error: function(xhr, status, error) {
                        alert('Server error: ' + error + '. Please check console for details.');
                        console.error('Upload error:', xhr);
                        btn.prop('disabled', false).text('Submit Changes');
                    }
                });
            });
        });
    </script>
}
