@model FileMatrix_Pabiran_.Models.RetentionPolicy
@*
    FileMatrix Governance Suite (Retention Settings).
    
    RESPONSIBILITY: Configures the automated lifecycle for workplace documents.
    
    DESIGN PATTERNS:
    1. Dual-Step Pipeline: Clearly separates 'Archive' (Safe Storage) from 
       'Delete' (Irreversible Removal) to prevent data loss.
    2. Visual Feedback: Uses an SVG-driven 'Process Flow Visualization' to 
       map numeric settings to a mental model of the document lifecycle.
    3. Global Switch: Master 'IsEnabled' toggle allows for non-destructive 
       pausing of automation workers.
*@
@{
    ViewData["Title"] = "Retention Settings";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
@section Head {
    <link rel="stylesheet" href="~/css/admin/retention.css" asp-append-version="true" />
}
    <div class="retention-header reveal-on-scroll">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index")" class="text-indigo text-decoration-none fw-600">Workplace</a></li>
                        <li class="breadcrumb-item active fw-600">Retention Policy</li>
                    </ol>
                </nav>
                <h1 class="display-5 fw-800 text-slate-900 mb-2">@(ViewBag.CurrentWorkplace?.Name ?? "Workplace") Retention</h1>
                <p class="text-slate-500 fs-5 mb-0">Manage automated document lifecycles for your organization.</p>
            </div>
            <a href="@Url.Action("Index")" class="btn btn-white shadow-sm rounded-pill px-4 py-2 border-slate-200 hover-lift d-flex align-items-center gap-2">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"></path></svg>
                <span class="fw-bold">Exit Settings</span>
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-indigo-glass alert-dismissible fade show border-0 reveal-on-scroll mb-4" role="alert">
            <div class="d-flex align-items-center gap-3">
                <div class="alert-icon-ring bg-indigo-500 text-white">
                    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                </div>
                <div>
                    <strong class="d-block text-indigo-900">Settings Updated</strong>
                    <span class="text-indigo-700">@TempData["SuccessMessage"]</span>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-xl-8">
            <div class="retention-card glass reveal-on-scroll">
                <form asp-action="Retention" method="post">
                    <div class="card-hero mb-5">
                        <div class="d-flex align-items-center justify-content-between section-highlight p-4 rounded-4 mb-4">
                            <div class="d-flex align-items-center gap-4">
                                <div class="icon-square bg-indigo-gradient text-white shadow-indigo">
                                    <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                                </div>
                                <div>
                                    <h4 class="fw-bold text-slate-900 mb-1">Workplace Automation</h4>
                                    <p class="text-slate-500 mb-0">Enable or disable retention rules for this workplace</p>
                                </div>
                            </div>
                            <div class="form-check form-switch custom-switch-lg">
                                <input class="form-check-input" type="checkbox" asp-for="IsEnabled">
                            </div>
                        </div>
                    </div>

                    <div class="lifecycle-rules row g-4 mb-5">
                        <div class="col-md-6">
                            <div class="rule-box p-4 rounded-4 transition-all">
                                <div class="d-flex align-items-center gap-3 mb-4">
                                    <div class="icon-blob bg-blue-100 text-blue-600">
                                        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
                                    </div>
                                    <h5 class="fw-bold text-slate-800 mb-0">Step 1: Auto-Archive</h5>
                                </div>
                                <div class="rule-content">
                                    <label class="form-label text-slate-500 fw-700 small text-uppercase tracking-wider">Move to archive after</label>
                                    <div class="custom-input-group">
                                        <input type="number" asp-for="AutoArchiveAfterDays" class="form-control" placeholder="90">
                                        <span class="input-suffix">Days</span>
                                    </div>
                                    <p class="text-slate-400 small mt-2">Active documents older than this will be moved to the safe archive.</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="rule-box p-4 rounded-4 transition-all danger-zone">
                                <div class="d-flex align-items-center gap-3 mb-4">
                                    <div class="icon-blob bg-rose-100 text-rose-600">
                                        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                    </div>
                                    <h5 class="fw-bold text-slate-800 mb-0">Step 2: Auto-Delete</h5>
                                </div>
                                <div class="rule-content">
                                    <label class="form-label text-slate-500 fw-700 small text-uppercase tracking-wider">Permanently delete after</label>
                                    <div class="custom-input-group">
                                        <input type="number" asp-for="AutoDeleteAfterDays" class="form-control" placeholder="365">
                                        <span class="input-suffix">Days</span>
                                    </div>
                                    <p class="text-rose-400 small mt-2"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg> Caution: Deletion from archive is irreversible.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* PIPELINE VISUALIZATION: 
                       Maps the abstract 'Days' settings to a linear progression 
                       to help admins visualize the impact of their policy changes. *@
                    <div class="lifecycle-visual mb-5">
                        <h6 class="text-slate-400 fw-700 small text-uppercase tracking-widest mb-4 text-center">Process Flow Visualization</h6>
                        <div class="visual-track p-4 rounded-4">
                            <div class="row align-items-center text-center">
                                <div class="col">
                                    <div class="visual-node active">
                                        <div class="node-dot"></div>
                                        <span class="d-block fw-bold text-slate-800 small">Active</span>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <div class="visual-arrow">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="visual-node archive">
                                        <div class="node-dot"></div>
                                        <span class="d-block fw-bold text-slate-800 small">Archived</span>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <div class="visual-arrow">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="visual-node delete">
                                        <div class="node-dot"></div>
                                        <span class="d-block fw-bold text-slate-800 small">Deleted</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center justify-content-between p-4 bg-slate-50 rounded-4 border border-slate-100">
                        <div class="text-slate-500 small d-flex align-items-center gap-2">
                            <div class="pulse-indicator"></div>
                            Policies are enforced daily by the RetentionWorker service.
                        </div>
                        <button type="submit" class="btn btn-indigo-gradient rounded-pill px-5 py-3 fw-bold shadow-indigo hover-lift">
                            Update Policy Settings
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="info-sidebar position-sticky" style="top: 2rem;">
                <div class="card glass-dark text-white border-0 rounded-5 mb-4 overflow-hidden">
                    <div class="card-body p-4 position-relative z-1">
                        <div class="mb-4">
                            <div class="icon-square bg-white bg-opacity-20 text-white mb-3">
                                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            </div>
                            <h5 class="fw-bold mb-2 text-white">Workplace Governance</h5>
                            <p class="text-white text-opacity-75 small mb-0">These policies are specific to **@ViewBag.CurrentWorkplace?.Name**. They help you maintain workspace hygiene automatically.</p>
                        </div>
                        
                        <div class="feature-item d-flex gap-3 mb-3">
                            <div class="feature-icon bg-white bg-opacity-10 rounded-circle flex-shrink-0">✓</div>
                            <div class="small text-white text-opacity-90">Reduces manual archive workload</div>
                        </div>
                        <div class="feature-item d-flex gap-3 mb-3">
                            <div class="feature-icon bg-white bg-opacity-10 rounded-circle flex-shrink-0">✓</div>
                            <div class="small text-white text-opacity-90">Auto-cleans temporary documents</div>
                        </div>
                        <div class="feature-item d-flex gap-3">
                            <div class="feature-icon bg-white bg-opacity-10 rounded-circle flex-shrink-0">✓</div>
                            <div class="small text-white text-opacity-90">Improves storage efficiency</div>
                        </div>
                    </div>
                    <div class="glass-orb orb-1"></div>
                    <div class="glass-orb orb-2"></div>
                </div>

                <div class="px-3">
                    <h6 class="text-slate-400 fw-700 small text-uppercase tracking-widest mb-3">Related Controls</h6>
                    <div class="list-group list-group-flush border-0">
                        <a href="@Url.Action("Index")" class="list-group-item list-group-item-action bg-transparent border-0 px-0 d-flex align-items-center gap-3 py-3 hover-text-indigo">
                            <div class="p-2 rounded-3 bg-white shadow-sm border text-slate-400">
                                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
                            </div>
                            <div>
                                <div class="fw-bold text-slate-700 small">Manage Workplace</div>
                                <p class="mb-0 text-slate-400 tiny">Back to document list</p>
                            </div>
                        </a>
                        <a href="#" class="list-group-item list-group-item-action bg-transparent border-0 px-0 d-flex align-items-center gap-3 py-3 hover-text-indigo">
                            <div class="p-2 rounded-3 bg-white shadow-sm border text-slate-400">
                                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line></svg>
                            </div>
                            <div>
                                <div class="fw-bold text-slate-700 small">Audit Logs</div>
                                <p class="mb-0 text-slate-400 tiny">View automation triggers</p>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

