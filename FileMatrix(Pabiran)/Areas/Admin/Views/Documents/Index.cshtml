</div>

<!-- Action Confirmation Modal (Premium) -->
<div class="modal fade" id="actionConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 shadow border-0 overflow-visible">
            <div class="modal-body p-4 text-center">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                
                <div id="confirm-icon-wrapper" class="mx-auto mb-4 d-flex align-items-center justify-content-center rounded-circle shadow-sm" style="width: 80px; height: 80px; background: #fff;">
                    <!-- Icon injected via JS -->
                </div>

                <h4 class="fw-bold text-dark mb-2" id="confirm-title">Are you sure?</h4>
                <p class="text-muted mb-4" id="confirm-message">This action cannot be undone.</p>
                
                <div id="retention-notice-area" class="alert d-none text-start border-0 mb-4" style="background: #f8fafc; border-radius: 1rem; padding: 1.25rem;">
                    <div class="d-flex gap-3">
                        <div class="text-indigo">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1 text-dark">Retention Notice</h6>
                            <p class="small text-muted mb-0" id="retention-message">
                                Documents in archive are automatically deleted after <span id="retention-days">---</span> days. 
                                This document will be permanently removed on <strong id="deletion-date-str">---</strong>.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-3">
                    <button type="button" class="btn btn-light w-100 py-3 fw-bold rounded-pill shadow-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary w-100 py-3 fw-bold rounded-pill shadow-sm" id="confirm-action-btn">Confirm</button>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            // Retention Logic
            const retentionPolicy = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.RetentionPolicy));
            
            let confirmModalInstance = null;

            function showConfirmModal(options) {
                const modalEl = document.getElementById('actionConfirmModal');
                if (!modalEl) return;

                if (!confirmModalInstance) {
                    confirmModalInstance = new bootstrap.Modal(modalEl);
                }
                
                const btn = $('#confirm-action-btn');
                const iconWrapper = $('#confirm-icon-wrapper');
                
                $('#confirm-title').text(options.title || 'Are you sure?');
                $('#confirm-message').text(options.message || 'This action cannot be undone.');
                
                // Icon styling
                iconWrapper.html(options.icon || '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>');
                iconWrapper.css('color', options.iconColor || '#6366f1');
                
                // Button styling
                btn.removeClass('btn-primary btn-danger btn-warning').addClass(options.btnClass || 'btn-primary');
                btn.text(options.btnText || 'Confirm');
                
                // Retention Notice
                if (options.showRetention && retentionPolicy && retentionPolicy.AutoDeleteAfterDays) {
                    $('#retention-notice-area').removeClass('d-none');
                    $('#retention-days').text(retentionPolicy.AutoDeleteAfterDays);
                    
                    const deleteDate = new Date();
                    deleteDate.setDate(deleteDate.getDate() + retentionPolicy.AutoDeleteAfterDays);
                    $('#deletion-date-str').text(deleteDate.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }));
                } else {
                    $('#retention-notice-area').addClass('d-none');
                }
                
                btn.off('click').on('click', function() {
                    const originalText = btn.text();
                    btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span> Processing...');
                    
                    options.onConfirm(() => {
                        confirmModalInstance.hide();
                        btn.prop('disabled', false).text(originalText);
                    });
                });
                
                confirmModalInstance.show();
            }

            // View Toggle Logic
            const docsContainer = $('#docs-container');
            const gridBtn = $('.view-toggle-btn[title="Grid View"]');
            const listBtn = $('.view-toggle-btn[title="List View"]');

            function setViewMode(mode) {
                if (mode === 'list') {
                    docsContainer.addClass('list-view-mode');
                    listBtn.addClass('active');
                    gridBtn.removeClass('active');
                } else {
                    docsContainer.removeClass('list-view-mode');
                    gridBtn.addClass('active');
                    listBtn.removeClass('active');
                }
                localStorage.setItem('fm_docs_view_mode', mode);
            }

            // Init from preference
            const savedMode = localStorage.getItem('fm_docs_view_mode');
            if (savedMode) {
                setViewMode(savedMode);
            }

            gridBtn.click(function() { setViewMode('grid'); });
            listBtn.click(function() { setViewMode('list'); });

            // Favorite Toggle
            $('.favorite-toggle').click(function (e) {
                e.preventDefault();
                e.stopPropagation();
                var btn = $(this);
                var id = btn.data('id');

                $.post('@Url.Action("ToggleFavorite")', { id: id }, function (res) {
                    if (res.success) {
                        btn.toggleClass('is-favorite', res.isFavorite);
                    }
                });
            });

            // Status Toggle
            $('.status-toggle').click(function (e) {
                e.preventDefault();
                var btn = $(this);
                var id = btn.data('id');
                var status = btn.data('status');

                $.post('@Url.Action("UpdateStatus")', { id: id, status: status }, function (res) {
                    if (res.success) {
                        var badge = $('#status-badge-' + id);
                        badge.attr('class', 'doc-status-badge ' + res.status.toLowerCase());
                        badge.text(res.status.toLowerCase());
                        
                        btn.html((res.status === 'Published' 
                            ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg> Set as Draft'
                            : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg> Publish'));
                    }
                });
            });

            // Archive Document
            $('.archive-doc').click(function (e) {
                e.preventDefault();
                var id = $(this).data('id');
                var title = $(this).closest('.doc-card').find('.doc-title').text() || 'this document';

                showConfirmModal({
                    title: 'Archive Document',
                    message: `Are you sure you want to archive "${title}"? It will be moved to the archive section.`,
                    btnText: 'Archive',
                    btnClass: 'btn-primary',
                    icon: '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="21 8 21 21 3 21 3 8"></polyline><rect x="1" y="3" width="22" height="5"></rect><line x1="10" y1="12" x2="14" y2="12"></line></svg>',
                    showRetention: true,
                    onConfirm: (done) => {
                        $.post('@Url.Action("Archive")', { id: id }, function (res) {
                            done();
                            if (res.success) {
                                $('#doc-container-' + id).fadeOut(300, function () { $(this).remove(); });
                            }
                        });
                    }
                });
            });

            // Restore Document
            $('.restore-doc').click(function (e) {
                e.preventDefault();
                var id = $(this).data('id');
                $.post('@Url.Action("Restore")', { id: id }, function (res) {
                    if (res.success) {
                        $('#doc-container-' + id).fadeOut(300, function () { $(this).remove(); });
                    }
                });
            });

            // Delete Document
            $('.delete-doc').click(function (e) {
                e.preventDefault();
                var id = $(this).data('id');
                var title = $(this).closest('.doc-card').find('.doc-title').text() || 'this document';

                showConfirmModal({
                    title: 'Permanently Delete',
                    message: `Are you sure you want to permanently delete "${title}"? This action cannot be undone.`,
                    btnText: 'Delete Permanently',
                    btnClass: 'btn-danger',
                    icon: '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#dc3545" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>',
                    showRetention: false,
                    onConfirm: (done) => {
                        $.post('@Url.Action("Delete")', { id: id }, function (res) {
                            done();
                            if (res.success) {
                                $('#doc-container-' + id).fadeOut(300, function () { $(this).remove(); });
                            }
                        });
                    }
                });
            });

            // Version History
            let currentDocId = null;

            $('.view-history').click(function(e) {
                e.preventDefault();
                var id = $(this).data('id');
                var title = $(this).data('title');
                currentDocId = id;
                $('#historyModalTitle').text('Version History');
                $('#historyModalSubtitle').text(title);
                loadVersionHistory(id);
                $('#versionHistoryModal').modal('show');
            });

            function loadVersionHistory(id) {
                $('#version-history-timeline').html('<div class="text-center py-4 text-muted"><div class="spinner-border spinner-border-sm me-2"></div> Loading...</div>');
                $.get('@Url.Action("VersionHistory")', { id: id }, function(res) {
                    if (res.success) {
                        var html = '';
                        res.versions.forEach(function(v) {
                            html += `
                                <div class="version-card">
                                    <div class="version-dot"></div>
                                    <div class="version-header">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="p-2 bg-primary-subtle rounded-3">
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f46e5" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                            </div>
                                            <span class="version-title">Version ${v.versionNumber}</span>
                                            ${v.isCurrent ? '<span class="version-badge bg-success-subtle text-success">Current</span>' : ''}
                                        </div>
                                    </div>
                                    <div class="version-meta">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                        ${v.uploadedAt}
                                    </div>
                                    <div class="version-meta">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                        ${v.uploadedBy}
                                    </div>
                                    <div class="small fw-bold text-muted mt-2">Size: ${v.fileSize}</div>
                                    ${v.changeNote ? `<div class="version-notes"><strong>Changes:</strong> ${v.changeNote}</div>` : ''}
                                    <div class="mt-3 d-flex gap-2">
                                        <a href="/Admin/Documents/Download/${id}?versionId=${v.versionID}" class="btn btn-sm btn-primary fw-bold" style="border-radius:6px; font-size:0.75rem;">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="me-1"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
                                            Download
                                        </a>
                                        ${!v.isCurrent && v.canRestore ? `
                                            <div class="restore-wrapper" data-vid="${v.versionID}">
                                                <button class="btn btn-sm btn-outline-secondary fw-bold restore-btn" style="border-radius:6px; font-size:0.75rem;">Restore</button>
                                                <div class="restore-confirm d-none gap-2">
                                                    <span class="small fw-bold text-danger me-1">Confirm?</span>
                                                    <button class="btn btn-sm btn-danger fw-bold confirm-restore-btn" style="border-radius:6px; font-size:0.75rem; padding: 0.25rem 0.6rem;">Yes</button>
                                                    <button class="btn btn-sm btn-light border fw-bold cancel-restore-btn" style="border-radius:6px; font-size:0.75rem; padding: 0.25rem 0.6rem;">No</button>
                                                </div>
                                            </div>
                                        ` : ''}
                                    </div>
                                </div>
                            `;
                        });
                        $('#version-history-timeline').html(html || '<div class="text-center py-4 text-muted">No history found.</div>');
                        
                        // Attach restore handlers
                        $('.restore-btn').click(function() {
                            var wrapper = $(this).closest('.restore-wrapper');
                            $(this).hide();
                            wrapper.find('.restore-confirm').removeClass('d-none').addClass('d-flex align-items-center');
                        });

                        $('.cancel-restore-btn').click(function() {
                            var wrapper = $(this).closest('.restore-wrapper');
                            wrapper.find('.restore-confirm').addClass('d-none').removeClass('d-flex');
                            wrapper.find('.restore-btn').show();
                        });

                        $('.confirm-restore-btn').click(function() {
                            var wrapper = $(this).closest('.restore-wrapper');
                            var vid = wrapper.data('vid');
                            var btn = $(this);
                            
                            btn.prop('disabled', true).text('...');
                            wrapper.find('.cancel-restore-btn').hide();
                            
                            $.post('@Url.Action("RestoreVersion")', { versionId: vid }, function(r) {
                                if (r.success) {
                                    location.reload();
                                } else {
                                    alert('Failed to restore: ' + r.message);
                                    btn.prop('disabled', false).text('Yes');
                                    wrapper.find('.cancel-restore-btn').show();
                                }
                            }).fail(function() {
                                alert('Server error occurred while restoring.');
                                btn.prop('disabled', false).text('Yes');
                                wrapper.find('.cancel-restore-btn').show();
                            });
                        });
                    }
                });
            }

            // Version Upload handlers
            // Manual click handler removed as label handles it natively now

            $('#version-file-input').change(function() {
                if (this.files && this.files.length > 0) {
                    $('#upload-form-area').slideDown();
                    $('#version-upload-trigger').hide();
                }
            });

            $('#cancel-version-upload').click(function() {
                $('#upload-form-area').slideUp();
                $('#version-upload-trigger').show();
                $('#version-file-input').val('');
                $('#version-notes-input').val('');
            });

            $('#submit-version-upload').click(function() {
                if (!currentDocId) return;
                var fileInput = document.getElementById('version-file-input');
                if (!fileInput.files || fileInput.files.length == 0) return;

                // Check file size (100MB limit)
                if (fileInput.files[0].size > 104857600) {
                    alert('File is too large. Maximum size is 100MB.');
                    return;
                }

                var formData = new FormData();
                formData.append('documentId', currentDocId);
                formData.append('file', fileInput.files[0]);
                formData.append('changeNote', $('#version-notes-input').val());

                var btn = $(this);
                btn.prop('disabled', true).text('Uploading...');

                $.ajax({
                    url: '@Url.Action("UploadVersion")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(r) {
                        if (r.success) {
                            location.reload();
                        } else {
                            alert('Upload failed: ' + r.message);
                            btn.prop('disabled', false).text('Submit Changes');
                        }
                    },
                    error: function(xhr, status, error) {
                        alert('Server error: ' + error + '. Please check console for details.');
                        console.error('Upload error:', xhr);
                        btn.prop('disabled', false).text('Submit Changes');
                    }
                });
            });

            // Share Document Logic (Google Docs Style)
            var currentShareDocId = null;

            $('.share-doc').click(function(e) {
                e.preventDefault();
                currentShareDocId = $(this).data('id');
                // Try to find title
                var card = $(this).closest('.doc-card');
                var docTitle = card.find('.doc-title').text().trim();
                // If list view
                if (!docTitle) docTitle = $(this).closest('tr').find('.doc-title').text().trim();
                
                $('#share-doc-title').text(docTitle || 'Document');
                
                $('#shareModal').modal('show');
                loadShareDetails(currentShareDocId);
            });

            function loadShareDetails(docId) {
                // Reset UI
                $('#share-people-list').html('<div class="text-center py-3 text-muted"><div class="spinner-border spinner-border-sm me-2"></div> Loading...</div>');
                // Default state: Restricted
                $('#general-access-label').text('Restricted');
                $('#public-role-wrapper').hide();
                $('#general-access-desc').text('Only people with access can open with the link');
                $('#general-access-bg').addClass('bg-light').removeClass('bg-primary-subtle text-primary bg-success-subtle text-success');
                $('#general-access-icon').html('<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>');
                
                $.get('@Url.Action("GetShareStatus")', { id: docId }, function(res) {
                    if (res.success) {
                        renderShareUI(res);
                    } else {
                        $('#share-people-list').html('<div class="text-center text-danger py-2">Failed to load details</div>');
                    }
                });
            }

            function renderShareUI(data) {
                var peopleListHtml = '';
                
                // Owner
                if (data.owner) {
                    peopleListHtml += renderPersonItem(data.owner, 'Owner', false);
                }

                // Permissions (Existing Users)
                if (data.permissions && data.permissions.length > 0) {
                    data.permissions.forEach(function(p) {
                        peopleListHtml += renderPersonItem(p, p.role, true, false);
                    });
                }

                // Pending Invitations (New Users)
                if (data.pendingInvites && data.pendingInvites.length > 0) {
                    data.pendingInvites.forEach(function(i) {
                        peopleListHtml += renderPersonItem(i, i.role, false, true);
                    });
                }
                
                $('#share-people-list').html(peopleListHtml);

                // General Access
                if (data.isPublic) {
                    $('#general-access-label').text('Anyone with the link');
                    $('#public-role-label').text(data.publicAccessLevel);
                    $('#public-role-wrapper').show();
                    $('#general-access-desc').text('Anyone on the internet with the link can ' + data.publicAccessLevel.toLowerCase());
                    $('#general-access-icon').html('<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>');
                    $('#general-access-bg').removeClass('bg-light').addClass('bg-primary-subtle text-primary');
                } else {
                    $('#general-access-label').text('Restricted');
                    $('#public-role-wrapper').hide();
                    $('#general-access-desc').text('Only people with access can open with the link');
                    $('#general-access-icon').html('<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>');
                    $('#general-access-bg').addClass('bg-light').removeClass('bg-primary-subtle text-primary');
                }
                
                // Unified Link System: Always use the token-based link provided by the server
                $('#share-copy-link-btn').data('link', data.publicLink);
            }

            function renderPersonItem(user, role, isRemovable, isPending) {
                var name = user.userDisplayName || user.email || '?';
                var initial = name.charAt(0).toUpperCase();

                if (isPending) name = user.email + ' (Pending)';
                var email = user.email || '';
                
                // Allow removing permission
                var removeBtn = isRemovable ? 
                    `<button class="btn btn-sm btn-link text-muted p-0 remove-perm-btn" data-id="${user.userID || user.userId}" title="Remove access">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>` : '';

                return `
                    <div class="d-flex align-items-center justify-content-between py-1">
                        <div class="d-flex align-items-center gap-3">
                            <div class="d-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-bold shadow-sm" style="width:36px; height:36px; font-size:14px;">
                                ${initial}
                            </div>
                            <div>
                                <div class="fw-bold text-dark" style="font-size: 0.9rem;">${name}</div>
                                <div class="text-muted" style="font-size: 0.75rem;">${email}</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                             <span class="text-muted small fw-bold">${role}</span>
                             ${removeBtn}
                        </div>
                    </div>`;
            }

            // General Access Change
            $(document).on('click', '.access-opt', function(e) {
                e.preventDefault();
                var val = $(this).data('val');
                if (val === 'Public') {
                    updatePublicAccess(true, 'Viewer'); 
                } else {
                    updatePublicAccess(false, null);
                }
            });

            $(document).on('click', '.role-opt', function(e) {
                e.preventDefault();
                updatePublicAccess(true, $(this).data('val'));
            });

            function updatePublicAccess(enabled, level) {
                // Determine current level if enabled is null
                if (enabled === true && level === null) level = $('#public-role-label').text();
                
                $.post('@Url.Action("UpdatePublicAccess")', { id: currentShareDocId, enabled: enabled, level: level }, function(res) {
                    if (res.success) {
                        loadShareDetails(currentShareDocId);
                    } else {
                        alert('Failed to update access.');
                        loadShareDetails(currentShareDocId); // Revert
                    }
                });
            }

            // Invite User
            $('#share-invite-btn').click(function() {
                var email = $('#share-email-input').val();
                var role = $('#share-role-input').val();
                if (!email) return;

                var btn = $(this);
                var originalText = btn.text();
                btn.prop('disabled', true).text('Sending...');

                $.post('@Url.Action("AddUserPermission")', { id: currentShareDocId, email: email, role: role }, function(res) {
                    btn.prop('disabled', false).text(originalText);
                    if (res.success) {
                         $('#share-email-input').val('');
                         if (res.pending) {
                             // Show a success banner for pending invites
                             var toastHtml = '<div id="share-invite-toast" class="alert alert-success d-flex align-items-center gap-2 mt-2 mb-0 p-2 rounded-3 small" style="font-size:0.82rem;">' +
                                 '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>' +
                                 '<span>' + (res.message || 'Invitation sent!') + '</span></div>';
                             $('#share-invite-toast').remove();
                             $('#share-email-input').closest('.d-flex').after(toastHtml);
                             setTimeout(function() { $('#share-invite-toast').fadeOut(400, function() { $(this).remove(); }); }, 4000);
                         } else {
                             loadShareDetails(currentShareDocId);
                         }
                    } else {
                        alert(res.message || 'Failed to add user.');
                    }
                });
            });

            // Remove permission
            $(document).on('click', '.remove-perm-btn', function() {
                var userId = $(this).data('id');
                // Use a smaller, cleaner confirm interaction or just confirm()
                if (confirm('Remove access for this user?')) {
                     $.post('@Url.Action("RemoveUserPermission")', { id: currentShareDocId, userId: userId }, function(res) {
                        if (res.success) {
                            loadShareDetails(currentShareDocId);
                        } else {
                            alert('Failed to remove user.');
                        }
                     });
                }
            });

            // Copy Link
            $('#share-copy-link-btn').click(function() {
                var link = $(this).data('link');
                var btn = $(this);
                var textSpan = $('#copy-link-text');
                var originalText = textSpan.text();
                
                if (navigator.clipboard) {
                    navigator.clipboard.writeText(link).then(function() {
                         textSpan.text('Link copied!');
                         setTimeout(function() { textSpan.text(originalText); }, 2000);
                    });
                } else {
                    // Fallback
                    var tempInput = document.createElement("input");
                    tempInput.value = link;
                    document.body.appendChild(tempInput);
                    tempInput.select();
                    document.execCommand("copy");
                    document.body.removeChild(tempInput);
                    
                    textSpan.text('Link copied!');
                    setTimeout(function() { textSpan.text(originalText); }, 2000);
                }
            });

            // Move to Category Logic
            var selectedCategoryId = null;

            $(document).on('click', '.move-doc', function(e) {
                e.preventDefault();
                var docId = $(this).data('id');
                var currentCatId = $(this).data('category-id');
                
                $('#move-doc-id').val(docId);
                selectedCategoryId = currentCatId || "";
                
                // Highlight current category
                $('.category-option').removeClass('selected');
                $('.category-option[data-id="' + selectedCategoryId + '"]').addClass('selected');
                
                $('#moveModal').modal('show');
            });

            $('.category-option').click(function() {
                $('.category-option').removeClass('selected');
                $(this).addClass('selected');
                selectedCategoryId = $(this).data('id');
            });

            $('#confirm-move-btn').click(function() {
                var docId = $('#move-doc-id').val();
                if (!docId) return;

                var btn = $(this);
                var originalText = btn.text();
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Moving...');

                $.post('@Url.Action("MoveToCategory")', { id: docId, categoryId: selectedCategoryId }, function(res) {
                    if (res.success) {
                        $('#moveModal').modal('hide');
                        // Update UI - specifically the category label on the card
                        var card = $('#doc-container-' + docId);
                        card.find('.doc-meta-item:first').html('<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg> ' + res.newCategoryName);
                        
                        // Update the data-category-id on the menu item too
                        card.find('.move-doc').data('category-id', selectedCategoryId);

                        btn.prop('disabled', false).text(originalText);
                    } else {
                        btn.prop('disabled', false).text(originalText);
                        alert('Failed to move document. Please try again.');
                    }
                });
            });
        });
    </script>
}
