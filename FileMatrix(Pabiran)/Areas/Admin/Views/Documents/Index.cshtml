                            <svg id="general-access-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                        </div>
                        <div class="d-flex flex-column">
                            <div class="dropdown">
                                <button class="btn btn-link p-0 fw-bold shadow-none text-dark d-flex align-items-center gap-2 dropdown-toggle custom-dropdown-toggle" type="button" id="general-access-dropdown" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.95rem; text-decoration: none;">
                                    <span id="general-access-label">Restricted</span>
                                </button>
                                <ul class="dropdown-menu border-0 shadow-lg p-2 rounded-3" aria-labelledby="general-access-dropdown" style="min-width: 200px;">
                                    <li><a class="dropdown-item rounded-2 py-2 access-opt" href="#" data-val="Restricted">Restricted</a></li>
                                    <li><a class="dropdown-item rounded-2 py-2 access-opt" href="#" data-val="Public">Anyone with the link</a></li>
                                </ul>
                            </div>
                            <div class="text-muted small" id="general-access-desc" style="font-size: 0.75rem; opacity: 0.8;">Only people with access can open with the link</div>
                        </div>
                    </div>
                    <div id="public-role-wrapper" style="display:none;">
                       <div class="dropdown">
                            <button class="btn btn-link p-0 fw-bold shadow-none text-primary d-flex align-items-center gap-2 dropdown-toggle custom-dropdown-toggle" type="button" id="public-role-dropdown" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.95rem; text-decoration: none;">
                                <span id="public-role-label">Viewer</span>
                            </button>
                            <ul class="dropdown-menu border-0 shadow-lg p-2 rounded-3 dropdown-menu-end" aria-labelledby="public-role-dropdown">
                                <li><a class="dropdown-item rounded-2 py-2 role-opt" href="#" data-val="Viewer">Viewer</a></li>
                                <li><a class="dropdown-item rounded-2 py-2 role-opt" href="#" data-val="Editor">Editor</a></li>
