@model FileMatrix_Pabiran_.Models.DocumentListViewModel
@*
    FileMatrix Document Hub (Index).
    
    RESPONSIBILITY: The primary dashboard for workplace asset management.
    UI CAPABILITIES: 
    1. View Modes: Persistent Grid/List toggle via LocalStorage.
    2. Grouping: Real-time grouping of assets by chronological status (Today, Yesterday, etc.).
    3. Action Orchestration: Central hub for all document lifecycle actions (Share, Archive, Versioning).
*@

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Documents";
    var membership = ViewBag.CurrentMembership as FileMatrix_Pabiran_.Models.WorkplaceMember;
    var canEdit = membership?.RoleID <= 2;
}

@section Head {
    <link rel="stylesheet" href="~/css/admin/documents.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-end docs-page-header reveal-on-scroll">
    <div>
        <h1 class="docs-page-title">Documents</h1>
        <p class="docs-page-subtitle">@Model.Documents.Count documents available</p>
    </div>
    @if (canEdit)
    {
        <div class="d-flex gap-2">
            <button class="btn btn-light rounded-pill px-4 fw-bold border d-flex align-items-center gap-2" style="height: 3.25rem;" data-bs-toggle="modal" data-bs-target="#createFolderModal">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path><line x1="12" y1="11" x2="12" y2="17"></line><line x1="9" y1="14" x2="15" y2="14"></line></svg>
                New Folder
            </button>
            <button class="btn docs-upload-btn" data-bs-toggle="modal" data-bs-target="#uploadModal">
                <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
                Upload Document
            </button>
            @if (membership?.RoleID == 1)
            {
                <a href="@Url.Action("Retention")" class="btn btn-outline-secondary rounded-pill px-3 d-flex align-items-center gap-2" title="Retention Settings">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                </a>
            }
        </div>
    }
</div>

<div class="docs-toolbar reveal-on-scroll">
    <form asp-action="Index" method="get" class="d-flex align-items-center gap-3">
        <div class="search-group">
            <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" name="query" class="form-control docs-search-input" placeholder="Search documents by name or tags..." value="@Model.SearchQuery" />
        </div>

        <select name="categoryId" class="form-select filter-select" onchange="this.form.submit()">
            <option value="">All Categories</option>
            @if (ViewBag.CategoriesList != null)
            {
                foreach (var cat in (IEnumerable<FileMatrix_Pabiran_.Models.Category>)ViewBag.CategoriesList)
                {
                    <option value="@cat.CategoryID" selected="@(Model.CategoryID == cat.CategoryID)">@cat.Name</option>
                }
            }
        </select>

        <select name="status" class="form-select filter-select" onchange="this.form.submit()">
            <option value="">Active Documents</option>
            <option value="Published" selected="@(Model.StatusFilter == "Published")">Published</option>
            <option value="Draft" selected="@(Model.StatusFilter == "Draft")">Draft</option>
            <option value="Archived" selected="@(Model.StatusFilter == "Archived")">Archived</option>
        </select>

        @* VIEW ORCHESTRATION: Grid/List Toggle. 
           Uses client-side CSS class toggling (list-view-mode) to transform the 
           entire document container without re-rendering HTML components. *@
        <div class="view-toggle">
            <button type="button" class="view-toggle-btn active" title="Grid View">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            </button>
            <button type="button" class="view-toggle-btn" title="List View">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
            </button>
        </div>
    </form>
</div>

<div class="row g-3 reveal-on-scroll" id="docs-container">
    @{
        string lastGroup = "";
    }
    @if (!Model.Documents.Any())
    {
        <div class="col-12">
            <div class="text-center py-5 bg-white rounded-5 border border-dashed border-2">
                <div class="mb-3 text-muted">
                    <svg width="64" height="64" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="opacity-25"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                </div>
                <h4 class="fw-bold text-dark">No documents found</h4>
                <p class="text-muted">No documents match your current filters or the workspace is empty.</p>
                @if (canEdit && string.IsNullOrEmpty(Model.SearchQuery) && !Model.CategoryID.HasValue)
                {
                    <button class="btn btn-primary rounded-pill px-5 py-2 fw-bold mt-2" data-bs-toggle="modal" data-bs-target="#uploadModal">Upload your first document</button>
                }
            </div>
        </div>
    }
    else
    {
        @foreach (var doc in Model.Documents)
        {
            var today = DateTime.Today;
            var dt = doc.UpdatedAt;
            string currentGroup;
            
            if (dt.Date == today) currentGroup = "Today";
            else if (dt.Date == today.AddDays(-1)) currentGroup = "Yesterday";
            else if (dt.Date >= today.AddDays(-7)) currentGroup = "This Week";
            else if (dt.Year == today.Year && dt.Month == today.Month) currentGroup = "This Month";
            else if (dt.Year == today.Year) currentGroup = dt.ToString("MMMM");
            else currentGroup = dt.ToString("MMMM yyyy");

            if (currentGroup != lastGroup)
            {
                lastGroup = currentGroup;
                @* CHRONOLOGICAL GROUPING: The 'Sticky Timeframe' pattern. 
                   Splits the flat document list into visual sections based on 
                   relative update dates to improve scannability. *@
                <div class="col-12">
                    <h2 class="date-section-header">@currentGroup</h2>
                </div>
            }
            <div class="col-md-6 col-lg-4 col-xl-3" id="doc-container-@doc.DocumentID">
                <div class="doc-card">
                    <div class="doc-card-actions">
                        <button class="action-btn favorite-toggle @(doc.IsFavorite ? "is-favorite" : "")" 
                                data-id="@doc.DocumentID" title="Toggle Favorite">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                        </button>
                        <div class="dropdown">
                            <button class="action-btn" data-bs-toggle="dropdown" aria-expanded="false">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="5" r="1"></circle><circle cx="12" cy="12" r="1"></circle><circle cx="12" cy="19" r="1"></circle></svg>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="@Url.Action("Details", new { id = doc.DocumentID })">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-preview"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg> Preview
                                </a></li>
                                <li><a class="dropdown-item view-history" href="#" data-id="@doc.DocumentID" data-title="@doc.Title">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-history"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> Version History
                                </a></li>
                                <li><a class="dropdown-item" href="@Url.Action("Download", new { id = doc.DocumentID })">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-download"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"></svg> Download
                                </a></li>
                                @if (canEdit || doc.IsShared)
                                {
                                    <li><a class="dropdown-item share-doc" href="#" data-id="@doc.DocumentID">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-share"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg> Share
                                    </a></li>
                                }
                                @if (canEdit)
                                {
                                    <li><a class="dropdown-item move-doc" href="#" data-id="@doc.DocumentID" data-category-id="@(doc.CategoryID ?? 0)">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-move"><path d="M7 10l5 5 5-5M12 15V3"></path><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg> Move to Category
                                    </a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                @if (canEdit)
                                {
                                    @if (doc.Status == "Draft")
                                    {
                                        <li><a class="dropdown-item status-toggle" href="#" data-id="@doc.DocumentID" data-status="Published">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-preview"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg> Publish
                                        </a></li>
                                    }
                                    else
                                    {
                                        <li><a class="dropdown-item status-toggle" href="#" data-id="@doc.DocumentID" data-status="Draft">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-draft"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg> Set as Draft
                                        </a></li>
                                    }
                                    @if (doc.Status == "Archived")
                                    {
                                        <li><a class="dropdown-item restore-doc" href="#" data-id="@doc.DocumentID">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-restore"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg> Restore
                                        </a></li>
                                    }
                                    else
                                    {
                                        <li><a class="dropdown-item archive-doc" href="#" data-id="@doc.DocumentID">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-archive"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="9" x2="15" y2="15"></line><line x1="15" y1="9" x2="9" y2="15"></line></svg> Archive
                                        </a></li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>

                    <div class="doc-badges">
                        <span class="doc-status-badge @(doc.Status.ToLower())" id="status-badge-@doc.DocumentID">@doc.Status.ToLower()</span>
                        @if (doc.IsShared)
                        {
                            <span class="doc-status-badge public-badge" title="Public Link Active">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="me-1" style="width:12px;height:12px;"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                                Public
                            </span>
                        }
                        else if (!string.IsNullOrEmpty(doc.PublicShareToken) && doc.PublicAccessLevel == "Restricted")
                        {
                             <span class="doc-status-badge private-badge" title="Restricted Link (Invite Only)">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="me-1" style="width:12px;height:12px;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                Restricted
                            </span>
                        }
                    </div>
                    
                    @{
                        string iconClass = "";
                        if (doc.IsWord) iconClass = "type-word";
                        else if (doc.IsExcel) iconClass = "type-excel";
                        else if (doc.IsPowerPoint) iconClass = "type-powerpoint";
                        else if (doc.IsPdf) iconClass = "type-pdf";
                        else if (doc.IsImage) iconClass = "type-image";
                        else if (doc.IsVideo) iconClass = "type-video";
                    }
                    
                    <div class="doc-icon-container @iconClass">
                        @if (doc.IsWord)
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><path d="M9 13h6"></path><path d="M9 17h3"></path></svg>
                        }
                        else if (doc.IsExcel)
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><path d="M8 13h8v4H8z"></path><path d="M12 13v4"></path></svg>
                        }
                        else if (doc.IsPowerPoint)
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><circle cx="12" cy="13" r="2"></circle><path d="M12 15v2"></path></svg>
                        }
                        else if (doc.IsPdf)
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><path d="M9 17h6"></path><path d="M12 12V17"></path></svg>
                        }
                        else if (doc.IsImage)
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                        }
                        else if (doc.IsVideo)
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><polygon points="10 8 10 12 13 10 10 8"></polygon><line x1="2" y1="17" x2="22" y2="17"></line><line x1="2" y1="21" x2="22" y2="21"></line></svg>
                        }
                        else
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                        }
                    </div>

                    <div class="doc-title" title="@doc.Title">@doc.Title</div>

                    <div class="doc-meta">
                        <div class="doc-meta-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                            @doc.CategoryName
                        </div>
                        <div class="doc-meta-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            @doc.Author
                        </div>
                        <div class="doc-meta-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            @doc.UpdatedAt.ToString("MMM dd, yyyy")
                        </div>
                    </div>

                    <div class="doc-footer">
                        <div class="doc-tags">
                            @foreach(var tag in doc.Tags)
                            {
                                <span class="doc-tag">@tag</span>
                            }
                        </div>
                        <div class="doc-size-badge">@doc.FileSizeFormatted</div>
                    </div>
                    
                    <a href="@Url.Action("Details", new { id = doc.DocumentID })" class="doc-card-link"></a>
                </div>
            </div>
        }
    }
</div>

<!-- Move to Category Modal -->
<div class="modal fade" id="moveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Move to Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="move-doc-id" />
                <div class="mb-3 text-center">
                    <div class="doc-icon-container mb-3" style="width: 50px; height: 50px; margin: 0 auto;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-move"><path d="M7 10l5 5 5-5M12 15V3"></path><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
                    </div>
                    <p class="text-muted small">Select a new destination for this document.</p>
                </div>
                <div class="mb-4">
                    <div class="row g-2" id="category-selection-grid">
                        <div class="col-6">
                            <div class="category-option p-3 rounded-4 border text-center cursor-pointer h-100 d-flex align-items-center justify-content-center" data-id="">
                                <div class="fw-bold small text-muted">Uncategorized</div>
                            </div>
                        </div>
                        @if (ViewBag.CategoriesList != null)
                        {
                            @foreach (var cat in (IEnumerable<FileMatrix_Pabiran_.Models.Category>)ViewBag.CategoriesList)
                            {
                                <div class="col-6">
                                    <div class="category-option p-3 rounded-4 border text-center cursor-pointer h-100 d-flex align-items-center justify-content-center" data-id="@cat.CategoryID">
                                        <div class="fw-bold small">@cat.Name</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary rounded-pill px-4" id="confirm-move-btn">Move Now</button>
            </div>
        </div>
    </div>
</div>


<!-- Upload Modal -->
@* 
   LIFECYCLE MODALS: FileMatrix uses a "Bootstrap Partial" pattern where 
   complex operations like Uploading and Sharing are isolated into 
   modal fragments to keep the main view clean and responsive.
*@
<div class="modal fade" id="uploadModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form action="@Url.Action("Upload", "Documents")" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Upload New Document</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-4">
                        <label class="form-label">Document Title</label>
                        <input type="text" name="Title" class="form-control" placeholder="e.g. Quarterly Report" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Description (Optional)</label>
                        <textarea name="Description" class="form-control" rows="2" placeholder="Tell us more about this file..."></textarea>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Category</label>
                        <select name="categoryId" class="form-select">
                            <option value="">Uncategorized</option>
                            @if (ViewBag.CategoriesList != null)
                            {
                                @foreach (var cat in (IEnumerable<FileMatrix_Pabiran_.Models.Category>)ViewBag.CategoriesList)
                                {
                                    <option value="@cat.CategoryID">@cat.Icon @cat.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Select File</label>
                        <input type="file" name="File" class="form-control" required />
                        <small class="text-muted mt-2 d-block">Supported formats: PDF, DOCX, TXT, XLSX (Max 100MB)</small>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 px-4 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold ms-2" id="start-upload-btn">
                        <span class="spinner-border spinner-border-sm me-2 d-none" role="status" aria-hidden="true"></span>
                        <span class="btn-text">Start Upload</span>
                    </button>
                    <small class="text-muted d-block w-100 text-center mt-3 d-none" id="upload-warning">
                        Please do not close this window while the file is uploading.
                    </small>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var uploadForm = document.querySelector('#uploadModal form');
        if (uploadForm) {
            uploadForm.addEventListener('submit', function(e) {
                var btn = this.querySelector('button[type="submit"]');
                var spinner = btn.querySelector('.spinner-border');
                var text = btn.querySelector('.btn-text');
                var warning = document.querySelector('#upload-warning');
                
                if (uploadForm.checkValidity()) {
                    // Check file size (100MB limit)
                    var fileInput = uploadForm.querySelector('input[type="file"]');
                    if (fileInput.files.length > 0) {
                        var fileSize = fileInput.files[0].size;
                        if (fileSize > 104857600) { // 100MB in bytes
                            e.preventDefault();
                            alert('File is too large. Maximum size is 100MB.');
                            return;
                        }
                    }

                    btn.disabled = true;
                    if (spinner) spinner.classList.remove('d-none');
                    if (text) text.textContent = 'Uploading...';
                    if (warning) warning.classList.remove('d-none');
                }
            });
        }
    });
</script>

