@*
    FileMatrix Administrative Shell (_AdminLayout).
    
    RESPONSIBILITY: Provides the high-fidelity dashboard environment for 
    authorized users (Admins, Editors, Viewers).
    
    ARCHITECTURE:
    1. Sidebar-Primary Shell: A full-height navigation system with mobile 
       toggle support (via site.js).
    2. Contextual Routing: Highlights navigation nodes based on the current 
       Area/Controller route data.
    3. Workplace Orchestrator: Handles the tenant-switching logic via a 
       dropdown that triggers the SwitchWorkplace identity routine.
    4. Toast Infrastructure: Hosting ground for the global premium notification system.
*@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/FileMatrix_Pabiran_.styles.css" />
    <link rel="stylesheet" href="~/css/shared/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin/layout.css" asp-append-version="true" />
    @RenderSection("Head", required: false)
</head>
@{
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? string.Empty;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
}
<body class="admin-shell">
    <!-- Mobile menu toggle button -->
    <button class="admin-menu-toggle" id="adminMenuToggle" aria-label="Toggle menu">
        <div class="admin-menu-toggle-icon">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </button>

    <!-- Overlay for mobile sidebar -->
    <div class="admin-sidebar-overlay" id="adminSidebarOverlay"></div>

    <div class="admin-wrapper d-flex">
        <aside class="admin-sidebar border-end" id="adminSidebar">
            <div class="admin-sidebar-header d-flex align-items-center">
                <div class="admin-logo-wrap me-2">
                    <img src="~/images/FileMatrix.png" alt="FileMatrix Logo" class="admin-logo-img" />
                </div>
                <div class="dropdown">
                    <a href="#" class="d-block text-decoration-none dropdown-toggle text-dark" id="workplaceDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="fw-bold admin-logo-text">@(ViewBag.CurrentWorkplace?.Name ?? "FileMatrix")</div>
                        <small class="text-muted">Switch Workspace</small>
                    </a>
                    <ul class="dropdown-menu shadow border-0" aria-labelledby="workplaceDropdown">
                        <li><h6 class="dropdown-header">My Workspaces</h6></li>
                        @if (ViewBag.MyWorkplaces != null)
                        {
                            foreach (dynamic wp in ViewBag.MyWorkplaces)
                            {
                                <li>
                                    <form method="post" action="/Account/SwitchWorkplace" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@wp.WorkplaceID" />
                                        <button type="submit" class="dropdown-item @(ViewBag.CurrentWorkplace?.WorkplaceID == wp.WorkplaceID ? "active fw-bold" : "")">
                                            @wp.Name
                                        </button>
                                    </form>
                                </li>
                            }
                            <li><hr class="dropdown-divider"></li>
                        }
                        <li>
                            <a class="dropdown-item" asp-area="" asp-controller="Organizations" asp-action="Index">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                                Manage / Join New
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            @{
                var membership = ViewBag.CurrentMembership as FileMatrix_Pabiran_.Models.WorkplaceMember;
                var roleName = membership?.RoleID switch {
                    1 => "Administrator",
                    2 => "Editor",
                    3 => "Viewer",
                    _ => "Guest"
                };
                var isAdmin = membership?.RoleID == 1;
            }

            <nav class="admin-nav nav flex-column px-3 pt-2">
                <a class="admin-nav-link @(currentController == "Admin" ? "active" : "")" asp-area="Admin" asp-controller="Admin" asp-action="Index">
                    <svg width="20" height="20" class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                    <span class="admin-nav-label">Dashboard</span>
                </a>
                <a class="admin-nav-link @(currentController == "Documents" ? "active" : "")" asp-area="Admin" asp-controller="Documents" asp-action="Index">
                    <svg width="20" height="20" class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    <span class="admin-nav-label">Documents</span>
                </a>
                
                @if (isAdmin)
                {
                    <a class="admin-nav-link @(currentController == "Users" ? "active" : "")" asp-area="Admin" asp-controller="Users" asp-action="Index">
                        <svg width="20" height="20" class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                        <span class="admin-nav-label">Users</span>
                    </a>
                    <a class="admin-nav-link @(currentController == "Categories" ? "active" : "")" asp-area="Admin" asp-controller="Categories" asp-action="Index">
                        <svg width="20" height="20" class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
                        <span class="admin-nav-label">Categories</span>
                    </a>
                    <a class="admin-nav-link @(currentController == "Audit" ? "active" : "")" asp-area="Admin" asp-controller="Audit" asp-action="Index">
                        <svg width="20" height="20" class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                        <span class="admin-nav-label">Audit Log</span>
                    </a>
                    <a class="admin-nav-link @(currentController == "Invitations" ? "active" : "")" asp-area="Admin" asp-controller="Invitations" asp-action="Index">
                        <svg width="20" height="20" class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg>
                        <span class="admin-nav-label">Invitations</span>
                    </a>
                }
            </nav>

            <div class="sidebar-footer mt-auto p-3">
                <div class="d-flex align-items-center mb-2">
                    <div class="avatar rounded-3 d-inline-flex align-items-center justify-content-center me-2">
                        @(!string.IsNullOrEmpty(User.Identity?.Name) ? User.Identity.Name.FirstOrDefault() : 'A')
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-semibold small text-truncate">@User.Identity?.Name</div>
                        <div class="text-muted small">@roleName</div>
                    </div>
                </div>
                <form method="post" action="/Account/Logout">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm w-100 admin-signout-btn">
                        <span class="me-1">&larr;</span> Sign Out
                    </button>
                </form>
            </div>
        </aside>

        <div class="admin-main flex-grow-1">
            <header class="admin-topbar d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
                <div>
                    <h4 class="mb-0">@((ViewData["Title"] as string) ?? "Dashboard")</h4>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <a asp-area="Admin" asp-controller="Notifications" asp-action="Index" class="btn btn-sm admin-icon-btn position-relative" aria-label="Notifications">
                        <svg width="18" height="18" class="admin-top-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                        <span class="admin-dot-badge"></span>
                    </a>
                    <a asp-area="Admin" asp-controller="Settings" asp-action="Index" class="btn btn-sm admin-icon-btn" aria-label="Settings">
                        <svg width="18" height="18" class="admin-top-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82H15a1.65 1.65 0 0 0 1 1.51v.09a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                    </a>
                </div>
            </header>

            <main class="p-4 admin-main-inner">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Global Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 2000;">
        <div id="globalToast" class="toast premium-toast hide align-items-center" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center gap-2">
                    <span id="globalToastIcon"></span>
                    <span id="globalToastMessage" class="fw-medium text-dark"></span>
                </div>
                <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/auth-modal.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // NOTIFICATION ARCHITECTURE: 
        // A unified toast system that abstracts Bootstrap's toast component 
        // into a premium interaction pattern with distinct visual states 
        // (Success/Error) and automatic icon injection.
        function showToast(message, type = 'success') {
            const toastEl = document.getElementById('globalToast');
            if (!toastEl) return;
            const toast = new bootstrap.Toast(toastEl, { delay: 4000 });
            
            const iconEl = document.getElementById('globalToastIcon');
            const messageEl = document.getElementById('globalToastMessage');
            
            toastEl.classList.remove('premium-toast--success', 'premium-toast--error');
            toastEl.classList.add(type === 'success' ? 'premium-toast--success' : 'premium-toast--error');
            
            if (type === 'success') {
                iconEl.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>';
            } else {
                iconEl.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>';
            }
            
            messageEl.innerText = message;
            toast.show();
        }

        // Mobile sidebar toggle functionality
        (function() {
            const menuToggle = document.getElementById('adminMenuToggle');
            const sidebar = document.getElementById('adminSidebar');
            const overlay = document.getElementById('adminSidebarOverlay');

            if (menuToggle && sidebar && overlay) {
                function toggleSidebar() {
                    sidebar.classList.toggle('mobile-open');
                    overlay.classList.toggle('active');
                }

                function closeSidebar() {
                    sidebar.classList.remove('mobile-open');
                    overlay.classList.remove('active');
                }

                menuToggle.addEventListener('click', toggleSidebar);
                overlay.addEventListener('click', closeSidebar);

                const navLinks = sidebar.querySelectorAll('.admin-nav-link');
                navLinks.forEach(link => {
                    link.addEventListener('click', function() {
                        if (window.innerWidth <= 991.98) {
                            closeSidebar();
                        }
                    });
                });

                window.addEventListener('resize', function() {
                    if (window.innerWidth > 991.98) {
                        closeSidebar();
                    }
                });
            }
            
            // Handle TempData messages on load
            window.addEventListener('load', () => {
                @if (TempData["SuccessMessage"] != null) {
                    <text>showToast('@Html.Raw(TempData["SuccessMessage"])', 'success');</text>
                }
                @if (TempData["ErrorMessage"] != null) {
                    <text>showToast('@Html.Raw(TempData["ErrorMessage"])', 'error');</text>
                }
                @if (TempData["InfoMessage"] != null) {
                    <text>showToast('@Html.Raw(TempData["InfoMessage"])', 'success');</text>
                }
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
