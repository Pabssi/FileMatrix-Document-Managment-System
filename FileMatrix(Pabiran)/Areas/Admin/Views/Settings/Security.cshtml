@{
    ViewData["Title"] = "Security Settings";
    bool hasPassword = ViewBag.HasPassword ?? false;
    bool hasAuthenticatorKey = ViewBag.HasAuthenticatorKey ?? false;
    bool email2FaEnabled = ViewBag.Email2FaEnabled as bool? ?? false;
    bool appMfaEnabled = ViewBag.AppMfaEnabled as bool? ?? false;
    bool authenticatorActive = appMfaEnabled;
    bool authenticatorPending = hasAuthenticatorKey && !appMfaEnabled && email2FaEnabled;
    bool showDisableTwoFactorModal = ViewBag.ShowDisableTwoFactorModal as bool? ?? false;
    var disableTwoFactorModalError = ViewBag.DisableTwoFactorModalError as string;
}

<div class="container-fluid py-4">
    <div class="mb-5 reveal-on-scroll">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-indigo text-decoration-none fw-bold small">Settings</a></li>
                <li class="breadcrumb-item active fw-bold text-muted small" aria-current="page">Login & Security</li>
            </ol>
        </nav>
        <h2 class="fw-extrabold text-dark mb-1">Login & Security</h2>
        <p class="text-muted fw-medium">Manage your password, Multi-Factor Authentication, and account security.</p>
    </div>

    <div class="row g-4 reveal-on-scroll">
        <div class="col-xl-8">
            <!-- Password Management Card -->
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden premium-card mb-4 transition-all">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                    <div class="d-flex align-items-center gap-2">
                        <div class="icon-box-sm bg-warning-subtle text-warning rounded-3 mt-n1">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                        </div>
                        <h5 class="fw-bold mb-0">Change Password</h5>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase ls-wide">Current Password</label>
                            <input type="password" name="oldPassword" class="form-control premium-form-control py-3 rounded-3" required placeholder="••••••••">
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small text-uppercase ls-wide">New Password</label>
                                <input type="password" name="newPassword" class="form-control premium-form-control py-3 rounded-3" required placeholder="Minimum 8 characters">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small text-uppercase ls-wide">Confirm New Password</label>
                                <input type="password" name="confirmPassword" class="form-control premium-form-control py-3 rounded-3" required placeholder="Repeat new password">
                            </div>
                        </div>
                        <div class="mt-5 pt-4 border-top">
                            <button type="submit" class="btn btn-warning text-dark fw-bold rounded-pill px-5 py-2 shadow-sm border-0">
                                Update Password
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- MFA Management Card -->
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden premium-card transition-all">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-2">
                            <div class="icon-box-sm bg-indigo-subtle text-indigo rounded-3 mt-n1">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                            </div>
                            <h5 class="fw-bold mb-0">Security Factors (2FA / MFA)</h5>
                        </div>
                        <span class="badge @((email2FaEnabled || appMfaEnabled) ? "bg-success" : "bg-slate-subtle text-slate") rounded-pill px-3 py-1 fw-bold" style="font-size: 0.7rem;">
                            @((email2FaEnabled || appMfaEnabled) ? "Extra sign-in ON" : "Standard login")
                        </span>
                    </div>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-4"><strong>Email 2FA</strong> sends a code to your inbox after your password. <strong>Authenticator MFA</strong> is optional and only applies after email 2FA is on — sign-in becomes password → email code → app code.</p>

                    <div class="d-flex flex-column gap-3">
                        <!-- Email Factor (2FA) -->
                        <div class="factor-item p-3 rounded-4 border d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 transition-all hover-shadow-sm">
                            <div class="d-flex align-items-center gap-3">
                                <div class="p-2 bg-light rounded-3 text-muted">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-0">Email 2FA</h6>
                                    <p class="text-muted small mb-0">Receive a sign-in code by email after your password.</p>
                                </div>
                            </div>
                            <div class="d-flex flex-shrink-0 gap-2">
                                @if (email2FaEnabled)
                                {
                                    <form asp-action="RequestDisableTwoFactor" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-light text-danger btn-sm rounded-pill px-4 fw-bold border">
                                            Disable
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="ToggleTwoFactor" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="enabled" value="true" />
                                        <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold">
                                            Enable
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        <!-- Authenticator App Factor (MFA) -->
                        <div class="factor-item p-3 rounded-4 border d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 transition-all hover-shadow-sm @(authenticatorActive ? "border-indigo border-2" : "") @(email2FaEnabled ? "" : "opacity-75")">
                            <div class="d-flex align-items-center gap-3">
                                <div class="p-2 bg-white rounded-3 text-indigo shadow-sm border">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
                                </div>
                                <div>
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <h6 class="fw-bold mb-0">Authenticator MFA (optional)</h6>
                                        @if (authenticatorActive)
                                        {
                                            <span class="badge bg-success-subtle text-success rounded-pill px-2 py-1" style="font-size: 0.65rem;">ACTIVE</span>
                                        }
                                        else if (authenticatorPending)
                                        {
                                            <span class="badge bg-warning-subtle text-warning rounded-pill px-2 py-1" style="font-size: 0.65rem;">SETUP IN PROGRESS</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-indigo-subtle text-indigo rounded-pill px-2 py-1" style="font-size: 0.65rem;">SECURE</span>
                                        }
                                    </div>
                                    <p class="text-muted small mb-0">Second step after your email code. Requires email 2FA to be enabled first.</p>
                                </div>
                            </div>
                            <div class="d-flex flex-column align-items-stretch gap-2 flex-shrink-0" style="min-width: 220px;">
                                @if (!email2FaEnabled)
                                {
                                    <span class="small text-muted text-center">Enable email 2FA first to add an authenticator.</span>
                                }
                                else if (authenticatorActive)
                                {
                                    <form asp-action="DisableAuthenticator" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <label class="form-label small text-muted mb-1">App code to confirm removal</label>
                                        <div class="input-group input-group-sm">
                                            <input type="text" name="code" class="form-control text-center fw-bold" maxlength="8" placeholder="000000" autocomplete="one-time-code" required inputmode="numeric" />
                                            <button type="submit" class="btn btn-outline-danger fw-bold px-3">Remove app</button>
                                        </div>
                                    </form>
                                }
                                else if (authenticatorPending)
                                {
                                    <a asp-action="EnableAuthenticator" class="btn btn-indigo-gradient text-white btn-sm rounded-pill px-4 fw-bold border-0 text-center">
                                        Finish setup
                                    </a>
                                }
                                else
                                {
                                    <form asp-action="StartAuthenticatorSetup" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-indigo btn-sm rounded-pill px-4 fw-bold w-100">
                                            Begin authenticator setup
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 alert alert-premium-indigo border-0 rounded-4 shadow-sm">
                        <div class="d-flex gap-3">
                            <div class="mt-1 text-indigo">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1 text-indigo">Security note</h6>
                                <p class="mb-0 small text-muted fw-medium lh-base">With both email 2FA and authenticator MFA on, you sign in with your password, then the email code, then the app code. Turning off email 2FA removes both steps after you confirm by email.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <!-- Security Audit Card -->
            <div class="card border-0 shadow-sm rounded-4 premium-card mb-4 transition-all">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-4 text-uppercase small text-muted ls-wide">Recent Activity</h6>
                    <div class="d-flex gap-3 mb-4">
                        <div class="icon-box-xs bg-light text-muted rounded-circle">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                        </div>
                        <div>
                            <p class="small fw-bold text-dark mb-0">Last Password Change</p>
                            <p class="text-muted x-small mb-0">@(hasPassword ? "On file" : "Not set")</p>
                        </div>
                    </div>
                    <div class="d-flex gap-3">
                        <div class="icon-box-xs bg-light text-muted rounded-circle">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        </div>
                        <div>
                            <p class="small fw-bold text-dark mb-0">Last Login Audit</p>
                            <p class="text-muted x-small mb-0">@DateTime.UtcNow.ToString("dd MMM yyyy, HH:mm") UTC</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sessions Card -->
            <div class="card border-0 shadow-sm rounded-4 premium-card transition-all">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-4 text-uppercase small text-muted ls-wide">Active Sessions</h6>
                    <div class="d-flex align-items-center mb-1">
                        <div class="pulse-green me-2"></div>
                        <span class="small fw-bold text-dark">Current browsing session</span>
                    </div>
                    <p class="text-muted x-small ms-3 mb-0">This device</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Confirm disable 2FA: same-page modal (avoids a separate route and keeps context on Security). -->
<div class="modal fade" id="disableTwoFactorModal" tabindex="-1" aria-labelledby="disableTwoFactorModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="disableTwoFactorModalLabel">Turn off email 2FA</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-2">
                <p class="text-muted small mb-3">We emailed you a 6-digit code. Enter it here to confirm you want to remove the extra sign-in step.</p>
                @if (!string.IsNullOrEmpty(disableTwoFactorModalError))
                {
                    <div class="alert alert-danger small py-2 mb-3" role="alert">@disableTwoFactorModalError</div>
                }
                <form asp-action="ConfirmDisableTwoFactor" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <label class="form-label fw-bold text-muted small text-uppercase ls-wide" for="disable2faCode">Email code</label>
                    <input id="disable2faCode" name="code" type="text" inputmode="numeric" autocomplete="one-time-code"
                           class="form-control premium-form-control py-3 rounded-3 text-center fw-bold mb-3"
                           maxlength="10" placeholder="000000" style="font-size: 1.25rem; letter-spacing: 6px;" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger text-white fw-bold rounded-pill py-2 border-0">Turn off 2FA</button>
                    </div>
                </form>
                <form asp-action="RequestDisableTwoFactor" method="post" class="text-center mb-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link text-indigo fw-semibold p-0 small text-decoration-none">Resend code</button>
                </form>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

@section Head {
    <link rel="stylesheet" href="~/css/admin/settings.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        (function () {
            var shouldOpen = @(showDisableTwoFactorModal ? "true" : "false");
            if (!shouldOpen) return;
            document.addEventListener('DOMContentLoaded', function () {
                var el = document.getElementById('disableTwoFactorModal');
                if (!el || typeof bootstrap === 'undefined' || !bootstrap.Modal) return;
                var modal = new bootstrap.Modal(el);
                modal.show();
                var input = document.getElementById('disable2faCode');
                if (input) setTimeout(function () { input.focus(); }, 400);
            });
        })();
    </script>
}
