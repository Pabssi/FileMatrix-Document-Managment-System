@{
    ViewData["Title"] = "Configure Authenticator App";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <div class="mb-5 reveal-on-scroll">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-indigo text-decoration-none fw-bold small">Settings</a></li>
                <li class="breadcrumb-item"><a asp-action="Security" class="text-indigo text-decoration-none fw-bold small">Security</a></li>
                <li class="breadcrumb-item active fw-bold text-muted small" aria-current="page">Setup Authenticator</li>
            </ol>
        </nav>
        <h2 class="fw-extrabold text-dark mb-1">Setup Authenticator App</h2>
        <p class="text-muted fw-medium">Add an extra layer of security using a TOTP authenticator app.</p>
    </div>

    <div class="row justify-content-center reveal-on-scroll">
        <div class="col-xl-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden premium-card transition-all">
                <div class="card-body p-5">
                    <div class="text-center mb-5">
                        <div class="icon-box-lg bg-indigo-subtle text-indigo rounded-circle mx-auto mb-3">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
                        </div>
                        <h4 class="fw-bold text-dark">Scan QR Code</h4>
                        <p class="text-muted">Open your authenticator app (like Google Authenticator or Authy) and scan this code.</p>
                    </div>

                    <div class="d-flex justify-content-center mb-5 p-3 bg-white border rounded-4 shadow-sm mx-auto" style="width: fit-content;" id="qrCode">
                        <!-- QR Code will be rendered here by JS -->
                    </div>

                    <div class="alert alert-light border rounded-4 p-3 mb-5">
                        <p class="small fw-bold text-muted text-uppercase ls-wide mb-2">Can't scan the code?</p>
                        <p class="small text-muted mb-2">Enter this secret key manually into your app:</p>
                        <div class="d-flex align-items-center gap-2">
                            <code class="bg-white border rounded px-3 py-2 fw-bold text-indigo flex-grow-1 text-center" style="font-size: 1.1rem; letter-spacing: 2px;">@ViewBag.SharedKey</code>
                        </div>
                    </div>

                    <form asp-action="EnableAuthenticator" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase ls-wide">Verification Code</label>
                            <input type="text" name="code" class="form-control premium-form-control py-3 rounded-3 text-center fw-bold" 
                                   required placeholder="000 000" maxlength="7" autocomplete="off" style="font-size: 1.5rem; letter-spacing: 10px;">
                            <div class="text-danger small mt-2">@Html.ValidationMessage("code")</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-indigo-gradient text-white fw-bold rounded-pill py-3 shadow-sm border-0">
                                Verify & Activate MFA
                            </button>
                            <a asp-action="Security" class="btn btn-link text-muted fw-bold text-decoration-none">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Head {
    <link rel="stylesheet" href="~/css/admin/settings.css" asp-append-version="true" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    <script>
        new QRCode(document.getElementById("qrCode"), {
            text: "@Html.Raw(ViewBag.AuthenticatorUri)",
            width: 200,
            height: 200,
            colorDark : "#1e1b4b",
            colorLight : "#ffffff",
            correctLevel : QRCode.CorrectLevel.H
        });
    </script>
}
