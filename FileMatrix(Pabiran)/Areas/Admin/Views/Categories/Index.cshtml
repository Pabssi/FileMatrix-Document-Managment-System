@model IEnumerable<FileMatrix_Pabiran_.Models.Category>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Categories";
    var membership = ViewBag.CurrentMembership as FileMatrix_Pabiran_.Models.WorkplaceMember;
    var isAdmin = membership?.RoleID == 1;
    var counts = ViewBag.CategoryCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

@section Head {
    <link rel="stylesheet" href="~/css/admin/categories.css" asp-append-version="true" />
}

<div class="categories-page-header d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4 reveal-on-scroll">
    <div>
        <h1 class="categories-page-title">Category Management</h1>
        <p class="categories-page-subtitle">Organize and tag your @ViewBag.CurrentWorkplace?.Name documents.</p>
    </div>
    @if (isAdmin)
    {
        <button type="button" class="btn btn-primary d-flex align-items-center gap-2 px-4 fw-bold" 
                data-bs-toggle="modal" data-bs-target="#createCategoryModal"
                style="border-radius:999px;background:linear-gradient(135deg,#4f46e5,#6366f1);border:none;height:42px;">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
            Add Category
        </button>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 bg-white rounded-4 border border-dashed reveal-on-scroll">
        <div class="mb-3 opacity-25">
            <svg width="64" height="64" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M7 7h10M7 12h10M7 17h10M4 4h16a2 2 0 012 2v12a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2z"/></svg>
        </div>
        <h5 class="fw-bold text-dark">No categories yet</h5>
        <p class="text-muted">Create categories to better browse your workspace.</p>
        @if (isAdmin)
        {
            <button class="btn btn-outline-primary rounded-pill px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#createCategoryModal">Create First Category</button>
        }
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4 reveal-on-scroll">
        @foreach (var cat in Model)
        {
            <div class="col">
                <div class="category-card">
                    <div class="category-icon-box" style="color: @cat.Color">
                        @cat.Icon
                    </div>
                    <div>
                        <div class="category-name">@cat.Name</div>
                        <div class="category-count">@(counts.ContainsKey(cat.CategoryID) ? counts[cat.CategoryID] : 0) documents</div>
                    </div>
                    @if (isAdmin)
                    {
                        <div class="category-actions">
                            <button class="category-action-btn" title="Edit" data-bs-toggle="modal" data-bs-target="#editModal-@cat.CategoryID">
                                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            </button>
                            <form asp-action="Delete" asp-route-id="@cat.CategoryID" method="post" onsubmit="return confirm('Delete this category? Documents will remain uncategorized.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="category-action-btn category-action-btn--delete" title="Delete">
                                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                </button>
                            </form>
                        </div>

                        <!-- Edit Modal -->
                        <div class="modal fade" id="editModal-@cat.CategoryID" tabindex="-1">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content shadow-lg">
                                    <form asp-action="Edit" asp-route-id="@cat.CategoryID" method="post">
                                        @Html.AntiForgeryToken()
                                        <div class="modal-header">
                                            <h5 class="fw-bold m-0">Edit Category</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body p-4">
                                            <div class="mb-3">
                                                <label class="form-label">Category Name</label>
                                                <input type="text" name="name" class="form-control" value="@cat.Name" required />
                                            </div>
                                            <div class="row">
                                                <div class="col-6 mb-3">
                                                    <label class="form-label">Icon (Emoji)</label>
                                                    <input type="text" name="icon" class="form-control" value="@cat.Icon" />
                                                </div>
                                                <div class="col-6 mb-3">
                                                    <label class="form-label">Color</label>
                                                    <input type="color" name="color" class="form-control form-control-color w-100" value="@cat.Color" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="modal-footer border-0">
                                            <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Save Changes</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

<!-- Create Modal -->
@if (isAdmin)
{
    <div class="modal fade" id="createCategoryModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="fw-bold m-0">Add New Category</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="mb-3">
                            <label class="form-label">Category Name</label>
                            <input type="text" name="name" class="form-control" placeholder="e.g. Legal, Finance, Marketing" required />
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">Icon (Emoji)</label>
                                <input type="text" name="icon" class="form-control" value="📁" />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">Color</label>
                                <input type="color" name="color" class="form-control form-control-color w-100" value="#6366f1" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Create Category</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
