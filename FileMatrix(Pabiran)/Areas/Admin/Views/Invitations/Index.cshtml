@model IEnumerable<FileMatrix_Pabiran_.Models.WorkplaceInvitation>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Invitations";
    var membership = ViewBag.CurrentMembership as FileMatrix_Pabiran_.Models.WorkplaceMember;
    var isAdmin = membership?.RoleID == 1;
}

@section Head {
    <link rel="stylesheet" href="~/css/admin/invitations.css" asp-append-version="true" />
}

<div class="invitations-page-header d-flex justify-content-between align-items-center flex-wrap gap-3 mb-5 reveal-on-scroll">
    <div>
        <h1 class="invitations-page-title">Member Invitations</h1>
        <p class="invitations-page-subtitle">Invite new members to collaborate in <strong>@ViewBag.CurrentWorkplace?.Name</strong>.</p>
    </div>
    @if (isAdmin)
    {
        <button type="button" class="btn btn-primary d-flex align-items-center gap-2 px-4 fw-bold shadow-lg" 
                data-bs-toggle="modal" data-bs-target="#createInvitationModal"
                style="border-radius:1rem;background:linear-gradient(135deg,#4f46e5,#6366f1);border:none;height:52px;font-size:1rem;">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
            Create Invitation
        </button>
    }
</div>

<div class="row g-4 mb-5 reveal-on-scroll">
    <div class="col-md-4">
        <div class="invitation-stat-card">
            <div class="invitation-stat-icon" style="background: rgba(79, 70, 229, 0.1); color: #4f46e5;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
            </div>
            <div>
                <div class="invitation-stat-value">@ViewBag.ActiveLinks</div>
                <div class="invitation-stat-label">Active Invites</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="invitation-stat-card">
            <div class="invitation-stat-icon" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <div>
                <div class="invitation-stat-value">@(ViewBag.JoinedMembers ?? 0)</div>
                <div class="invitation-stat-label">Joined Members</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="invitation-stat-card">
            <div class="invitation-stat-icon" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            </div>
            <div>
                <div class="invitation-stat-value">@ViewBag.ExpiredLinks</div>
                <div class="invitation-stat-label">Expired/Inactive</div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 bg-white rounded-5 border border-dashed reveal-on-scroll shadow-sm" style="border-width: 2px !important; border-color: #e2e8f0 !important;">
        <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-4" style="width: 80px; height: 80px;">
            <svg width="40" height="40" fill="none" stroke="#94a3b8" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="16" y1="11" x2="22" y2="11"/></svg>
        </div>
        <h3 class="fw-extrabold text-dark h4">No invitations yet</h3>
        <p class="text-muted mx-auto mb-4" style="max-width: 400px;">Start growing your team by generating a secure invitation link for your collaborators.</p>
        @if (isAdmin)
        {
            <button class="btn btn-primary rounded-pill px-5 fw-bold" data-bs-toggle="modal" data-bs-target="#createInvitationModal" style="background:linear-gradient(135deg,#4f46e5,#6366f1);border:none;height:48px;">Create Your First Invite</button>
        }
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 reveal-on-scroll">
        @foreach (var invite in Model)
        {
            var isExpired = (invite.ExpiresAt != null && invite.ExpiresAt < DateTime.UtcNow) || (invite.UsageLimit != null && invite.UsageCount >= invite.UsageLimit);
            var displayStatus = invite.Status == "used" ? "used" : (isExpired ? "expired" : "pending");
            var joinUrl = Url.Action("Join", "Organizations", new { area = "", token = invite.Token }, protocol: Context.Request.Scheme);
            
            <div class="col">
                <div class="invitation-card">
                    <div class="invitation-actions">
                        @if (displayStatus == "pending")
                        {
                            <button type="button" class="invitation-action-btn invitation-copy-btn" title="Copy Invitation Link" onclick="copyToClipboard('@joinUrl', this)">
                                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg>
                            </button>
                        }
                        @if (isAdmin)
                        {
                            <button type="button" class="invitation-action-btn invitation-delete-btn" title="Delete Invitation" onclick="confirmDelete(@invite.InvitationID)">
                                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                            </button>
                        }
                    </div>
                    
                    <div>
                        <span class="invitation-status invitation-status--@displayStatus">@displayStatus</span>
                        <div class="invitation-email mt-2">@(string.IsNullOrEmpty(invite.Email) ? "Public Organization Link" : invite.Email)</div>
                        <div class="d-flex align-items-center gap-2 mt-2">
                            <div class="invitation-role">Role: @(invite.RoleID == 1 ? "Admin" : invite.RoleID == 2 ? "Editor" : "Viewer")</div>
                        </div>
                    </div>

                    @if (displayStatus == "pending")
                    {
                        <div class="invitation-code-container">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <small class="text-muted fw-bold" style="font-size: .65rem; text-transform: uppercase; letter-spacing: 0.05em;">Access Link</small>
                                @if (invite.UsageLimit != null)
                                {
                                    <span class="invitation-usage">@invite.UsageCount / @invite.UsageLimit uses</span>
                                }
                            </div>
                            <div class="small text-truncate text-primary fw-bold" style="max-width: 100%;">@joinUrl</div>
                        </div>
                    }

                    <div class="invitation-meta">
                        <div class="d-flex justify-content-between">
                            <span>Created @invite.CreatedAt.ToString("MMM dd, yyyy")</span>
                            @if (displayStatus == "pending")
                            {
                                @if (invite.ExpiresAt != null)
                                {
                                    <span class="text-warning fw-bold">Expires in @((invite.ExpiresAt.Value - DateTime.UtcNow).Days)d</span>
                                }
                                else
                                {
                                    <span class="text-success fw-bold">Permanent</span>
                                }
                            }
                            else
                            {
                                <span class="text-danger fw-bold">Inactive</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Create Modal -->
@if (isAdmin)
{
    <div class="modal fade" id="createInvitationModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header border-0 pt-4 px-4">
                        <div>
                            <h5 class="fw-extrabold m-0 h4">Invite Team Member</h5>
                            <p class="text-muted small mb-0">Securely bring new collaborators into your workspace.</p>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="mb-4">
                            <label class="form-label">Recipient Email (Optional)</label>
                            <input type="email" name="email" class="form-control" placeholder="e.g. colleague@company.com" />
                            <div class="form-text small fw-medium mt-2">Leave blank to create a <strong>public access link</strong>.</div>
                        </div>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Assign Role</label>
                                <select name="roleId" class="form-select fw-bold">
                                    <option value="3" selected>Viewer (Read-only)</option>
                                    <option value="2">Editor (Full access)</option>
                                    <option value="1">Admin (Full Control)</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Usage Limit</label>
                                <input type="number" name="usageLimit" class="form-control" placeholder="No limit" min="1" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Link Expiration</label>
                                <select name="expiryDays" class="form-select fw-bold">
                                    <option value="1">24 Hours (Urgent)</option>
                                    <option value="7" selected>7 Days (Standard)</option>
                                    <option value="30">30 Days (Extended)</option>
                                    <option value="0">Never (Permanent)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4 pt-0">
                        <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-extrabold" style="background:linear-gradient(135deg,#4f46e5,#6366f1);border:none;height:48px;">Generate Secure Link</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content text-center p-4">
                <div class="mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 text-danger rounded-circle mb-3" style="width: 72px; height: 72px;">
                        <svg width="36" height="36" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    </div>
                    <h5 class="fw-extrabold text-dark h4">Revoke invite?</h5>
                    <p class="text-muted small mb-0">This link will immediately become invalid. Users won't be able to join using it.</p>
                </div>
                <div class="d-flex flex-column gap-2">
                    <form id="deleteForm" method="post" action="">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger w-100 rounded-pill fw-bold" style="height:48px;">Yes, Revoke Access</button>
                    </form>
                    <button type="button" class="btn btn-light w-100 rounded-pill fw-bold" style="height:48px;" data-bs-dismiss="modal">Keep Active</button>
                </div>
            </div>
        </div>
    </div>
}

<script>
    function copyToClipboard(text, btn) {
        navigator.clipboard.writeText(text).then(function() {
            if (typeof showToast === 'function') {
                showToast('Invitation link copied to clipboard!');
            }
            
            // Temporary visual feedback on button
            const originalIcon = btn.innerHTML;
            btn.innerHTML = '<svg width="18" height="18" fill="none" stroke="#10b981" stroke-width="3" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>';
            btn.style.borderColor = '#10b981';
            btn.style.backgroundColor = '#f0fdf4';
            setTimeout(() => {
                btn.innerHTML = originalIcon;
                btn.style.borderColor = '#e2e8f0';
                btn.style.backgroundColor = 'white';
            }, 2000);
        }, function(err) {
            console.error('Could not copy text: ', err);
        });
    }

    function confirmDelete(id) {
        const form = document.getElementById('deleteForm');
        form.action = `/Admin/Invitations/Delete/${id}`;
        const modal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
        modal.show();
    }
</script>
