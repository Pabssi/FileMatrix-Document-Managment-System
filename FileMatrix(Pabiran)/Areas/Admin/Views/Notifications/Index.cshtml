@model IEnumerable<FileMatrix_Pabiran_.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
@section Head {
    <link rel="stylesheet" href="~/css/admin/notifications.css" asp-append-version="true" />
}
    <div class="mb-5 reveal-on-scroll">
        <h2 class="fw-extrabold text-dark mb-1">Notifications</h2>
        <p class="text-muted fw-medium">Stay updated on document changes, mentions, and system alerts.</p>
    </div>

    <div class="row g-4 reveal-on-scroll">
        <div class="col-xl-9">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden border-hover-indigo transition-all">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">Recent Activity</h5>
                    <div class="dropdown">
                        <button class="btn btn-light btn-sm rounded-pill px-3 fw-bold text-muted small text-uppercase ls-wide border-0 shadow-none" type="button" data-bs-toggle="dropdown">
                            Filter
                        </button>
                        <ul class="dropdown-menu border-0 shadow-lg rounded-4 overflow-hidden">
                            <li><a class="dropdown-item py-2 px-4 small fw-medium" href="#">All Notifications</a></li>
                            <li><a class="dropdown-item py-2 px-4 small fw-medium text-indigo" href="#">Unread</a></li>
                            <li><a class="dropdown-item py-2 px-4 small fw-medium" href="#">System Alerts</a></li>
                        </ul>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var notification in Model)
                            {
                                <div class="list-group-item list-group-item-action border-0 px-4 py-3 @(!notification.IsSent ? "bg-light-indigo" : "")">
                                    <div class="d-flex align-items-start gap-3">
                                        <div class="notif-icon-box @(notification.IsSent ? "bg-slate-100 text-slate-400" : "bg-indigo-100 text-indigo-600") mt-1">
                                            @if (notification.Type == "Document")
                                            {
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                            }
                                            else
                                            {
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                                            }
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <h6 class="fw-bold mb-0 @(!notification.IsSent ? "text-indigo" : "text-dark")">@notification.Type</h6>
                                                <small class="text-muted fw-medium">@GetTimeAgo(notification.CreatedAt)</small>
                                            </div>
                                            <p class="mb-0 text-secondary small fw-medium">@notification.Message</p>
                                        </div>
                                        @if (!notification.IsSent)
                                        {
                                            <div class="notif-dot"></div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <div class="mb-3 text-muted">
                                    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.2;"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                                </div>
                                <h4 class="fw-extrabold text-dark">All caught up!</h4>
                                <p class="text-muted mx-auto fw-medium" style="max-width: 400px;">You have no new notifications at this time. We'll alert you when something important happens.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 border-hover-indigo transition-all">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-4 text-uppercase small text-muted ls-wide">Preferences</h6>
                    <div class="form-check form-switch mb-3 custom-switch-indigo">
                        <input class="form-check-input" type="checkbox" id="emailNotif" checked>
                        <label class="form-check-label small fw-medium text-dark" for="emailNotif">Email Notifications</label>
                    </div>
                    <div class="form-check form-switch mb-3 custom-switch-indigo">
                        <input class="form-check-input" type="checkbox" id="pushNotif" checked>
                        <label class="form-check-label small fw-medium text-dark" for="pushNotif">Push Notifications</label>
                    </div>
                    <div class="form-check form-switch mb-3 custom-switch-indigo">
                        <input class="form-check-input" type="checkbox" id="mentionNotif" checked>
                        <label class="form-check-label small fw-medium text-dark" for="mentionNotif">Mentions Only</label>
                    </div>
                    
                    <hr class="my-4 opacity-5">
                    
                    <form asp-action="MarkAllAsRead" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-indigo text-white w-100 rounded-pill fw-bold py-2 shadow-sm">
                            Mark all as read
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    public string GetTimeAgo(DateTime dt)
    {
        var ts = DateTime.UtcNow - dt;
        if (ts.TotalMinutes < 1) return "Just now";
        if (ts.TotalHours < 1) return $"{(int)ts.TotalMinutes}m ago";
        if (ts.TotalDays < 1) return $"{(int)ts.TotalHours}h ago";
        if (ts.TotalDays < 7) return $"{(int)ts.TotalDays}d ago";
        return dt.ToString("MMM dd, yyyy");
    }
}

