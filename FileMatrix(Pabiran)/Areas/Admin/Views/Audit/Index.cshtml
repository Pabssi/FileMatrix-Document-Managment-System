@model IEnumerable<FileMatrix_Pabiran_.Models.AuditLog>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Audit Log";
    var actionTypes = ViewBag.ActionTypes as List<string> ?? new List<string>();
    var actionFilterCurrent = ViewBag.ActionFilter as string;
    var auditPage = ViewBag.AuditPage is int ap ? ap : 1;
    var auditTotalPages = ViewBag.AuditTotalPages is int tp ? tp : 1;
    var auditTotalFiltered = ViewBag.AuditTotalFiltered is int tf ? tf : 0;
    var auditPageSize = ViewBag.AuditPageSize is int ps ? ps : 20;
    var rowStart = auditTotalFiltered == 0 ? 0 : (auditPage - 1) * auditPageSize + 1;
    var rowEnd = Math.Min(auditPage * auditPageSize, auditTotalFiltered);
}

@section Head {
    <link rel="stylesheet" href="~/css/admin/audit.css" asp-append-version="true" />
}

<div class="audit-page-header d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4 reveal-on-scroll">
    <div>
        <h1 class="audit-page-title">Activity Log</h1>
        <p class="audit-page-subtitle">Consolidated system activities for <strong>@ViewBag.CurrentWorkplace?.Name</strong>.</p>
    </div>
    <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill px-3 fw-bold">
        Export History
    </button>
</div>

<div class="row g-3 mb-4 reveal-on-scroll">
    <div class="col-md-3">
        <div class="audit-stat-card">
            <div class="audit-stat-icon" style="background:#eff6ff;color:#2563eb;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
            </div>
            <div>
                <div class="audit-stat-value">@ViewBag.TotalEvents</div>
                <div class="audit-stat-label">Total Events</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="audit-stat-card">
            <div class="audit-stat-icon" style="background:#ecfdf5;color:#047857;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            </div>
            <div>
                <div class="audit-stat-value">@ViewBag.DocumentActions</div>
                <div class="audit-stat-label">Documents</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="audit-stat-card">
            <div class="audit-stat-icon" style="background:#f3e8ff;color:#7c3aed;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            </div>
            <div>
                <div class="audit-stat-value">@ViewBag.UserActions</div>
                <div class="audit-stat-label">User Actions</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="audit-stat-card">
            <div class="audit-stat-icon" style="background:#fff7ed;color:#c2410c;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            </div>
            <div>
                <div class="audit-stat-value">@ViewBag.TodayEvents</div>
                <div class="audit-stat-label">Today</div>
            </div>
        </div>
    </div>
</div>

<form asp-area="Admin" asp-controller="Audit" asp-action="Index" method="get" class="audit-search-bar d-flex flex-wrap align-items-center gap-2 reveal-on-scroll">
    <div class="flex-grow-1">
        <input type="text" name="query" value="@ViewBag.Query"
               class="form-control audit-search-input"
               placeholder="Search logs by user, details, or entity..." />
    </div>
    <select name="actionFilter" class="form-select form-select-sm" style="max-width: 180px;border-radius:999px;height:2.5rem;" onchange="this.form.submit()">
        @* Boolean selected="False" still leaves the attribute present — browsers may pick the wrong option. *@
        @if (string.IsNullOrWhiteSpace(actionFilterCurrent))
        {
            <option value="" selected>All Actions</option>
        }
        else
        {
            <option value="">All Actions</option>
        }
        @foreach (var action in actionTypes)
        {
            if (string.Equals(actionFilterCurrent, action, StringComparison.Ordinal))
            {
                <option value="@action" selected>@action</option>
            }
            else
            {
                <option value="@action">@action</option>
            }
        }
    </select>
    <button type="submit" class="btn btn-dark rounded-pill px-3 fw-bold h-100" style="height:2.5rem !important;">Filter</button>
</form>

<div class="audit-timeline reveal-on-scroll">
    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted m-0">No activity logs found matching your filters.</p>
        </div>
    }
    else
    {
        <div class="audit-timeline-line">
            @foreach (var log in Model)
            {
                <div class="audit-entry">
                    <div class="audit-entry-dot"></div>
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <span class="audit-entry-badge">@log.Action (@log.EntityType)</span>
                            <div class="audit-entry-content">
                                <span class="audit-entry-user">
                                    @(log.User != null ? (log.User.DisplayName ?? log.User.Username) : "System")
                                </span><br />
                                @log.Details
                            </div>
                        </div>
                        <span class="audit-entry-time" title="@log.PerformedAt.ToString("g")">
                            @GetTimeAgo(log.PerformedAt)
                        </span>
                    </div>
                </div>
            }
        </div>
    }

    @if (auditTotalFiltered > 0)
    {
        var queryStr = ViewBag.Query as string;
        <nav class="audit-pager d-flex flex-wrap align-items-center justify-content-between gap-2 mt-3 pt-3 border-top">
            <span class="text-muted small">Showing @rowStart–@rowEnd of @auditTotalFiltered</span>
            @if (auditTotalPages > 1)
            {
                <div class="d-flex align-items-center gap-1">
                    @if (auditPage > 1)
                    {
                        <a class="btn btn-sm btn-outline-secondary rounded-pill"
                           asp-area="Admin" asp-controller="Audit" asp-action="Index"
                           asp-route-query="@queryStr" asp-route-actionFilter="@actionFilterCurrent" asp-route-page="@(auditPage - 1)">Previous</a>
                    }
                    else
                    {
                        <span class="btn btn-sm btn-outline-secondary rounded-pill disabled opacity-50">Previous</span>
                    }
                    <span class="small text-muted px-2">Page @auditPage of @auditTotalPages</span>
                    @if (auditPage < auditTotalPages)
                    {
                        <a class="btn btn-sm btn-outline-secondary rounded-pill"
                           asp-area="Admin" asp-controller="Audit" asp-action="Index"
                           asp-route-query="@queryStr" asp-route-actionFilter="@actionFilterCurrent" asp-route-page="@(auditPage + 1)">Next</a>
                    }
                    else
                    {
                        <span class="btn btn-sm btn-outline-secondary rounded-pill disabled opacity-50">Next</span>
                    }
                </div>
            }
        </nav>
    }
</div>

@functions {
    string GetTimeAgo(DateTime dateTime)
    {
        var span = DateTime.UtcNow - dateTime;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return dateTime.ToString("MMM dd");
    }
}
