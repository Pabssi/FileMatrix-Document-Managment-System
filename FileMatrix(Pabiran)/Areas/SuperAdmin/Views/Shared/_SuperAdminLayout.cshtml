@*
  Super Admin layout - completely separate from regular admin area
  This is for platform/system administrators who manage the entire system
*@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Super Admin - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/FileMatrix_Pabiran_.styles.css" />
    <link rel="stylesheet" href="~/css/shared/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/shared/layout-toast.css" asp-append-version="true" />
    @RenderSection("Head", required: false)
</head>
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    int? currentUserIdForSettings = null;
    var nameId = User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    if (int.TryParse(nameId, out var parsedUserId))
        currentUserIdForSettings = parsedUserId;
}
<body class="superadmin-shell" data-fm-superadmin-send-pin-url="@Url.Action("SendActionConfirmationPin", "SuperAdmin", new { area = "SuperAdmin" })">
    <!-- Mobile menu toggle button -->
    <button class="superadmin-menu-toggle" id="superadminMenuToggle" aria-label="Toggle menu">
        <div class="superadmin-menu-toggle-icon">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </button>

    <!-- Overlay for mobile sidebar -->
    <div class="superadmin-sidebar-overlay" id="superadminSidebarOverlay"></div>

    <div class="superadmin-wrapper d-flex">
        <aside class="superadmin-sidebar border-end" id="superadminSidebar">
            <div class="superadmin-sidebar-header d-flex align-items-center">
                <div class="superadmin-logo-wrap me-2">
                    <div class="superadmin-logo-inner"></div>
                </div>
                <div>
                    <div class="fw-bold superadmin-logo-text d-flex align-items-center gap-2">
                        FileMatrix
                        <span class="privacy-shield-badge">Standard</span>
                    </div>
                    <small class="text-muted">Platform Management</small>
                </div>
            </div>

            <nav class="superadmin-nav nav flex-column px-3 pt-2">
                <a class="superadmin-nav-link @(currentAction == "Index" ? "active" : "")" asp-area="SuperAdmin" asp-controller="SuperAdmin" asp-action="Index">
                    <span class="superadmin-nav-icon superadmin-icon-dashboard"></span>
                    <span class="superadmin-nav-label">Dashboard</span>
                </a>
                <a class="superadmin-nav-link @(currentAction == "Organizations" ? "active" : "")" asp-area="SuperAdmin" asp-controller="SuperAdmin" asp-action="Organizations">
                    <span class="superadmin-nav-icon superadmin-icon-org"></span>
                    <span class="superadmin-nav-label">Organizations</span>
                </a>
                <a class="superadmin-nav-link @(currentAction == "Users" || currentAction == "CreateSuperAdmin" ? "active" : "")" asp-area="SuperAdmin" asp-controller="SuperAdmin" asp-action="Users">
                    <span class="superadmin-nav-icon superadmin-icon-users"></span>
                    <span class="superadmin-nav-label">All Users</span>
                </a>
                <a class="superadmin-nav-link @(currentAction == "Documents" ? "active" : "")" asp-area="SuperAdmin" asp-controller="SuperAdmin" asp-action="Documents">
                    <span class="superadmin-nav-icon superadmin-icon-docs"></span>
                    <span class="superadmin-nav-label">System Documents</span>
                </a>
                <a class="superadmin-nav-link @(currentAction == "AuditLogs" ? "active" : "")" asp-area="SuperAdmin" asp-controller="SuperAdmin" asp-action="AuditLogs">
                    <span class="superadmin-nav-icon superadmin-icon-security"></span>
                    <span class="superadmin-nav-label">Audit Logs</span>
                </a>
                <a class="superadmin-nav-link @(currentAction == "LoginAttempts" ? "active" : "")" asp-area="SuperAdmin" asp-controller="SuperAdmin" asp-action="LoginAttempts">
                    <span class="superadmin-nav-icon superadmin-icon-security"></span>
                    <span class="superadmin-nav-label">Login Attempts</span>
                </a>
                <a class="superadmin-nav-link @(currentAction == "Settings" ? "active" : "")" asp-area="SuperAdmin" asp-controller="SuperAdmin" asp-action="Settings">
                    <span class="superadmin-nav-icon superadmin-icon-settings"></span>
                    <span class="superadmin-nav-label">System Settings</span>
                </a>
                <a class="superadmin-nav-link @(currentAction == "Analytics" ? "active" : "")" asp-area="SuperAdmin" asp-controller="SuperAdmin" asp-action="Analytics">
                    <span class="superadmin-nav-icon superadmin-icon-analytics"></span>
                    <span class="superadmin-nav-label">Analytics</span>
                </a>
                <a class="superadmin-nav-link @(currentAction == "Backfills" ? "active" : "")" asp-area="SuperAdmin" asp-controller="SuperAdmin" asp-action="Backfills">
                    <span class="superadmin-nav-icon superadmin-icon-backup"></span>
                    <span class="superadmin-nav-label">Backfills</span>
                </a>
            </nav>

            <div class="sidebar-footer mt-auto p-3">
                <div class="d-flex align-items-center mb-2">
                    <div class="avatar rounded-3 d-inline-flex align-items-center justify-content-center me-2" style="background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#ffffff;font-weight:600;width:32px;height:32px;">
                        @{
                            var name = User.Identity?.Name ?? "S";
                            var display = name.Contains("@") ? name.Split('@')[0] : name;
                            var initial = !string.IsNullOrEmpty(display) ? display[0].ToString().ToUpper() : "S";
                        }
                        @initial
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-semibold small text-truncate" style="color:#ffffff;">@(User.Identity?.Name?.Contains("@") == true ? User.Identity.Name.Split('@')[0] : User.Identity?.Name)</div>
                        <div class="small" style="color:#9ca3af;">Super Administrator</div>
                    </div>
                </div>
                <form method="post" action="/Account/Logout">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm w-100 superadmin-signout-btn">
                        <span class="me-1">&larr;</span> Sign Out
                    </button>
                </form>
            </div>
        </aside>

        <div class="superadmin-main flex-grow-1">
            <header class="superadmin-topbar d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
                <div class="d-flex align-items-center gap-3">
                    <h4 class="mb-0">@((ViewData["Title"] as string) ?? "Super Admin Dashboard")</h4>
                    <div class="privacy-banner">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                        Privacy Shield Active
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="audit-session-timer small text-muted d-none d-md-block">
                        Audit ID: <span class="fw-mono">@Guid.NewGuid().ToString("n").Substring(0, 8)</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button type="button" class="btn btn-sm superadmin-icon-btn position-relative" aria-label="Notifications">
                            <span class="superadmin-icon-dot"></span>
                            <span class="superadmin-dot-badge"></span>
                        </button>
                        @if (currentUserIdForSettings.HasValue)
                        {
                            <a class="btn btn-sm superadmin-icon-btn text-decoration-none" asp-area="SuperAdmin" asp-controller="UserSecurity" asp-action="Security" asp-route-id="@currentUserIdForSettings.Value" aria-label="Your password and MFA" title="Your sign-in security">
                                <span class="superadmin-icon-gear"></span>
                            </a>
                        }
                        else
                        {
                            <a class="btn btn-sm superadmin-icon-btn text-decoration-none" asp-area="SuperAdmin" asp-controller="SuperAdmin" asp-action="Settings" aria-label="System settings" title="System settings">
                                <span class="superadmin-icon-gear"></span>
                            </a>
                        }
                    </div>
                </div>
            </header>

            <main class="p-4 superadmin-main-inner">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                        <strong>Success!</strong> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["InfoMessage"] != null)
                {
                    <div class="alert alert-info alert-dismissible fade show mb-4" role="alert">
                        @TempData["InfoMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                        <strong>Error!</strong> @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    </div>

    @await Html.PartialAsync("_SuperAdminActionConfirmModal")

    <link rel="stylesheet" href="~/css/superadmin/layout.css" asp-append-version="true" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/superadmin-action-confirm.js" asp-append-version="true"></script>
    <script src="~/js/auth-modal.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Mobile sidebar toggle functionality
        (function() {
            const menuToggle = document.getElementById('superadminMenuToggle');
            const sidebar = document.getElementById('superadminSidebar');
            const overlay = document.getElementById('superadminSidebarOverlay');

            if (menuToggle && sidebar && overlay) {
                function toggleSidebar() {
                    sidebar.classList.toggle('mobile-open');
                    overlay.classList.toggle('active');
                }

                function closeSidebar() {
                    sidebar.classList.remove('mobile-open');
                    overlay.classList.remove('active');
                }

                menuToggle.addEventListener('click', toggleSidebar);
                overlay.addEventListener('click', closeSidebar);

                const navLinks = sidebar.querySelectorAll('.superadmin-nav-link');
                navLinks.forEach(link => {
                    link.addEventListener('click', function() {
                        if (window.innerWidth <= 991.98) {
                            closeSidebar();
                        }
                    });
                });

                window.addEventListener('resize', function() {
                    if (window.innerWidth > 991.98) {
                        closeSidebar();
                    }
                });
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
