@{
    Layout = "~/Areas/SuperAdmin/Views/Shared/_SuperAdminLayout.cshtml";
    ViewData["Title"] = "Organization Management";
}

@section Head {
    <link rel="stylesheet" href="~/css/superadmin/organizations.css" asp-append-version="true" />
}

<div class="superadmin-header d-flex justify-content-between align-items-end reveal-on-scroll">
    <div>
        <h1>Organizations</h1>
        <p>Monitor and manage all application workplaces.</p>
    </div>
    <a asp-action="ProvisionWorkplace" class="btn btn-primary px-4" style="border-radius: 0.75rem; background: #4f46e5; border: none; font-weight: 600;">
        + Provision New
    </a>
</div>

<div class="org-table-card reveal-on-scroll">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Organization</th>
                    <th>Status</th>
                    <th>Users</th>
                    <th>Assets</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.Organizations != null)
                {
                    foreach (var org in ViewBag.Organizations)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold text-dark">@org.Name</div>
                                <div class="org-id-badge">ID: FM-@org.WorkplaceID</div>
                            </td>
                            <td>
                                @if (org.IsActive)
                                {
                                    <span class="status-badge status-badge--active">
                                        <span style="width: 6px; height: 6px; border-radius: 50%; background: currentColor;"></span>
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-badge--suspended">
                                        <span style="width: 6px; height: 6px; border-radius: 50%; background: currentColor;"></span>
                                        Suspended
                                    </span>
                                }
                            </td>
                            <td class="fw-semibold">@org.UserCount</td>
                            <td>@org.DocumentCount </td>
                            <td class="text-muted">@(((DateTime)org.CreatedAt).ToString("MMM dd, yyyy"))</td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a href="#" class="action-btn" title="Edit Settings">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                    </a>
                                    <a href="#" class="action-btn" title="View Statistics">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                                    </a>
                                    <form asp-action="ToggleWorkplaceStatus" asp-route-id="@org.WorkplaceID" method="post" style="display:inline;">
                                        <button type="submit" class="action-btn action-btn--danger" title="Suspend Organization">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line></svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">No organizations found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
