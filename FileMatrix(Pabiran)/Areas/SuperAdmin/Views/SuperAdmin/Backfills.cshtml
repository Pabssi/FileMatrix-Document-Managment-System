@{
    Layout = "~/Areas/SuperAdmin/Views/Shared/_SuperAdminLayout.cshtml";
    ViewData["Title"] = "System Backfills";
    var tasks = ViewBag.Tasks as List<dynamic>;
}

@section Head {
    <link rel="stylesheet" href="~/css/superadmin/backfills.css" asp-append-version="true" />
}

<div class="superadmin-header reveal-on-scroll">
    <h1>System Backfills</h1>
    <p>Manage and monitor infrastructure standardization tasks (Backpacks).</p>
</div>

<div class="reveal-on-scroll">
@if (tasks != null && tasks.Any())
{
    @foreach (var task in tasks)
    {
        <div class="backfill-card d-flex align-items-center justify-content-between">
            <div>
                <div class="d-flex align-items-center gap-3 mb-1">
                    <h5 class="mb-0 fw-bold">@task.Name</h5>
                    <span class="status-badge status-@(task.Status.ToLower())">@task.Status</span>
                </div>
                <p class="text-muted small mb-1">@task.Description</p>
                @if (!string.IsNullOrEmpty(task.LastResult))
                {
                    <p class="text-primary x-small mb-1"><strong>Last Result:</strong> @task.LastResult</p>
                }
                <small class="text-muted">Last Run: @(task.LastRun?.ToString("MMM dd, yyyy HH:mm") ?? "Never")</small>
            </div>
            <form asp-action="RunTask" method="post">
                <input type="hidden" name="key" value="@task.Key" />
                <button type="submit" class="btn-run-task" @(task.Status == "Running" ? "disabled" : "")>
                    @(task.Status == "Running" ? "Processing..." : "Run Task Now")
                </button>
            </form>
        </div>
    }
}
    else
    {
        <div class="alert alert-info py-4 text-center">
            No system backfill tasks identified.
        </div>
    }
</div>
