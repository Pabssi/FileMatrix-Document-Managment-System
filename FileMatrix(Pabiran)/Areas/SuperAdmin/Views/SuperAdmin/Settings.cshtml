@model Dictionary<string, string>
@{
    Layout = "~/Areas/SuperAdmin/Views/Shared/_SuperAdminLayout.cshtml";
    ViewData["Title"] = "Platform Settings";

    string GetValue(string key) => Model.ContainsKey(key) ? Model[key] : "";
    bool IsChecked(string key) => GetValue(key).ToLower() == "true";
}

@section Head {
    <link rel="stylesheet" href="~/css/superadmin/settings.css" asp-append-version="true" />
}

<div class="superadmin-header">
    <h1>Platform Settings</h1>
    <p>Global configuration and system-wide feature toggles.</p>
</div>

<form asp-action="UpdateSettings" method="post">
    <div class="settings-grid">
        <!-- General Settings -->
        <div class="settings-card glass-card">
            <div class="settings-card-header">
                <h5 class="settings-card-title">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                    Platform Governance
                </h5>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <span class="setting-label">Public Registration</span>
                    <span class="setting-desc">Allow new users to register without an invitation.</span>
                </div>
                <div class="form-check form-switch custom-switch">
                    <input class="form-check-input" type="checkbox" name="settings[PublicRegistration]" value="true" @(IsChecked("PublicRegistration") ? "checked" : "")>
                    <input type="hidden" name="settings[PublicRegistration]" value="false" />
                </div>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <span class="setting-label">Workplace Creation</span>
                    <span class="setting-desc">Allow standard users to provision new organizations.</span>
                </div>
                <div class="form-check form-switch custom-switch">
                    <input class="form-check-input" type="checkbox" name="settings[WorkplaceCreation]" value="true" @(IsChecked("WorkplaceCreation") ? "checked" : "")>
                    <input type="hidden" name="settings[WorkplaceCreation]" value="false" />
                </div>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <span class="setting-label">Maintenance Mode</span>
                    <span class="setting-desc">Redirect all users to a maintenance page.</span>
                </div>
                <div class="form-check form-switch custom-switch">
                    <input class="form-check-input" type="checkbox" name="settings[MaintenanceMode]" value="true" @(IsChecked("MaintenanceMode") ? "checked" : "")>
                    <input type="hidden" name="settings[MaintenanceMode]" value="false" />
                </div>
            </div>
        </div>

        <!-- Security & Auth -->
        <div class="settings-card glass-card">
            <div class="settings-card-header">
                <h5 class="settings-card-title">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                    Identity & Access
                </h5>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <span class="setting-label">Two-Factor Authentication</span>
                    <span class="setting-desc">Enforce 2FA for all administrative accounts.</span>
                </div>
                <div class="form-check form-switch custom-switch">
                    <input class="form-check-input" type="checkbox" name="settings[TwoFactorEnforcement]" value="true" @(IsChecked("TwoFactorEnforcement") ? "checked" : "")>
                    <input type="hidden" name="settings[TwoFactorEnforcement]" value="false" />
                </div>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <span class="setting-label">Session Timeout</span>
                    <span class="setting-desc">Automatically sign out users after X minutes.</span>
                </div>
                <select class="form-select settings-select" name="settings[SessionTimeout]">
                    <option value="15" selected="@(GetValue("SessionTimeout") == "15")">15 mins</option>
                    <option value="30" selected="@(GetValue("SessionTimeout") == "30")">30 mins</option>
                    <option value="60" selected="@(GetValue("SessionTimeout") == "60")">1 hour</option>
                    <option value="240" selected="@(GetValue("SessionTimeout") == "240")">4 hours</option>
                </select>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <span class="setting-label">Password Complexity</span>
                    <span class="setting-desc">Enforce high-strength password requirements globally.</span>
                </div>
                <div class="form-check form-switch custom-switch">
                    <input class="form-check-input" type="checkbox" name="settings[PasswordComplexity]" value="true" @(IsChecked("PasswordComplexity") ? "checked" : "")>
                    <input type="hidden" name="settings[PasswordComplexity]" value="false" />
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5" style="max-width: 400px;">
        <button type="submit" class="btn-save-settings">
            Save Changes
        </button>
    </div>
</form>
