@using FileMatrix_Pabiran_.Models
@{
    Layout = "~/Areas/SuperAdmin/Views/Shared/_SuperAdminLayout.cshtml";
    ViewData["Title"] = "System Audit Logs";
    var logs = ViewBag.Logs as IEnumerable<AuditLog> ?? Enumerable.Empty<AuditLog>();
    var severity = ViewBag.Severity as string ?? "all";
    var totalCount = ViewBag.TotalCount is int tc ? tc : 0;
    var pageSize = ViewBag.PageSize is int ps ? ps : 25;
}

@section Head {
    <link rel="stylesheet" href="~/css/superadmin/audit-logs.css" asp-append-version="true" />
}

<div class="superadmin-header reveal-on-scroll">
    <h1>Audit Logs</h1>
    <p class="text-muted mb-0">Platform-wide activity. Use severity to focus on riskier events.</p>
</div>

<div class="d-flex flex-wrap align-items-center gap-3 mb-3 reveal-on-scroll">
    <div class="text-muted small">
        <strong>@totalCount</strong> row(s) match this filter.
    </div>
</div>

<form method="get" asp-area="SuperAdmin" asp-controller="SuperAdmin" asp-action="AuditLogs" class="sa-audit-toolbar reveal-on-scroll">
    <input type="hidden" name="page" value="1" />
    <div>
        <label class="form-label" for="al-severity">Severity</label>
        <select name="severity" id="al-severity" class="form-select form-select-sm" style="min-width: 12rem;" onchange="this.form.querySelector('input[name=page]').value='1'; this.form.submit();">
            @foreach (var o in new (string v, string l)[] { ("all", "All"), ("critical", "Critical (lockouts, deletions, key/share revoke)"), ("high", "High (failed sign-in, role/status, archive)"), ("normal", "Normal (other)") })
            {
                if (severity == o.v)
                {
                    <option value="@o.v" selected="selected">@o.l</option>
                }
                else
                {
                    <option value="@o.v">@o.l</option>
                }
            }
        </select>
    </div>
    <div class="text-muted small align-self-center">
        @pageSize rows per page.
    </div>
</form>

<div class="log-table-card reveal-on-scroll">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Severity</th>
                    <th>Timestamp</th>
                    <th>User ID</th>
                    <th>Action</th>
                    <th>Entity Type</th>
                    <th>Details</th>
                    <th>IP Address</th>
                </tr>
            </thead>
            <tbody>
                @if (logs.Any())
                {
                    foreach (var log in logs)
                    {
                        <tr>
                            <td><span class="sa-severity-badge @SuperAdminAuditSeverityUi.CssClassForPlatform(log)">@SuperAdminAuditSeverityUi.LabelForPlatform(log)</span></td>
                            <td class="log-timestamp">@log.PerformedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>
                                @if (log.UserID.HasValue)
                                {
                                    <span class="badge bg-light text-dark">#@log.UserID</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                <span class="log-action-badge @(log.Action?.ToLower().Contains("create") == true ? "log-action--create" : log.Action?.ToLower().Contains("update") == true ? "log-action--update" : log.Action?.ToLower().Contains("delete") == true ? "log-action--delete" : "log-action--login")">
                                    @log.Action
                                </span>
                            </td>
                            <td><span class="text-muted">@(log.EntityType ?? "—")</span></td>
                            <td>
                                <div class="log-details" title="@log.Details">@log.Details</div>
                            </td>
                            <td class="text-muted">@(log.IpAddress ?? "—")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <div class="text-muted mb-2">No audit rows for this filter.</div>
                            <a asp-area="SuperAdmin" asp-controller="SuperAdmin" asp-action="AuditLogs" asp-route-severity="all" asp-route-page="1">Clear severity filter</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("~/Areas/SuperAdmin/Views/Shared/_SuperAdminLogPager.cshtml")
