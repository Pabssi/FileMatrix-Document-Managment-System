@model FileMatrix_Pabiran_.Models.Workplace
@{
    Layout = "~/Areas/SuperAdmin/Views/Shared/_SuperAdminLayout.cshtml";
    ViewData["Title"] = "Provision New Organization";
}

@section Head {
    <link rel="stylesheet" href="~/css/superadmin/provision.css" asp-append-version="true" />
}

<div class="superadmin-header text-center reveal-on-scroll">
    <h1>Provision Organization</h1>
    <p>Onboard a new enterprise or workspace to the platform.</p>
</div>

<div class="provision-card reveal-on-scroll">
    <form asp-action="ProvisionWorkplace" method="post">
        <div class="row g-4">
            <div class="col-md-12">
                <label asp-for="Name" class="form-label">Organization Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Acme Corporation" required />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="col-md-12">
                <label asp-for="Slug" class="form-label">Workplace URL Slug</label>
                <div class="input-group">
                    <span class="input-group-text bg-light" style="border-radius: 12px 0 0 12px; border-right: none;">filematrix.com/</span>
                    <input asp-for="Slug" class="form-control" style="border-radius: 0 12px 12px 0;" placeholder="acme-corp" required />
                </div>
                <div class="input-hint">Unique identifier used in the URL. Only lowercase letters and hyphens.</div>
                <span asp-validation-for="Slug" class="text-danger small"></span>
            </div>

            <div class="col-md-12">
                <label asp-for="Description" class="form-label">Organization Description (Optional)</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief overview of this workplace..."></textarea>
            </div>

            <div class="col-md-12 text-center mt-5">
                <button type="submit" class="btn-provision">
                    Complete Provisioning
                </button>
                <div class="mt-3">
                    <a asp-action="Organizations" class="text-muted text-decoration-none small">Cancel and return to list</a>
                </div>
            </div>
        </div>
    </form>
</div>
